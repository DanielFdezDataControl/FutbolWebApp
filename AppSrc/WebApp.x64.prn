38299>>>    
38299>>>    Object oJugadorDD is a cjugadorDataDictionary
38301>>>        
38301>>>        Set pbUseDDSQLFilters to True
38302>>>        
38302>>>        Procedure OnConstrain
38305>>>            Forward Send OnConstrain
38307>>>            
38307>>>            Integer iLigaID iCont
38307>>>            String[] saEquiposDeLigaID
38308>>>            String sConsulta
38308>>>            
38308>>>            Send Request_Clear of Self
38309>>>            
38309>>>            Get Field_Current_Value of oLigaDD Field liga.ID to iLigaID
38310>>>           
38310>>>            Move iLigaID to equipo.LigaID
38311>>>            Send Request_Read to oEquipoDD FIRST_RECORD equipo.File_Number 1
38312>>>            While (Found)
38316>>>                Move equipo.ID to saEquiposDeLigaID[-1]                   
38317>>>                Send Request_Read to oEquipoDD NEXT_RECORD equipo.File_Number 1
38318>>>            Loop
38319>>>>
38319>>>            If (SizeOfArray(saEquiposDeLigaID) > 0) Begin
38321>>>                Move ("(jugador.equipoID = " + String(saEquiposDeLigaID[0]) + ")") to sConsulta                
38322>>>                For iCont from 1 to (SizeOfArray(saEquiposDeLigaID) - 1)
38328>>>>
38328>>>                    Move (sConsulta + " OR (jugador.equipoID = " + String(saEquiposDeLigaID[iCont]) + ")") to sConsulta
38329>>>                Loop                
38330>>>>
38330>>>            End            
38330>>>>
38330>>>            Set psSQLFilter to ("("+ sConsulta + ")")
38331>>>        End_Procedure
38332>>>        
38332>>>    End_Object // oJugadorDD
38333>>>    
