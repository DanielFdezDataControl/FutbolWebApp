39223>>>    // Add code to customize your Zoom View based on how it was invoked.
39223>>>    // Use NavigateData to determine the context this view will be used in.
39223>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
39226>>>
39226>>>        // if this view is being used in multiple contexts, you may need a block of code
39226>>>        // like this to handle customizations. This would include hiding rows and buttons
39226>>>        // (WebSet pbRender) and changing the values of various captions.
39226>>>        Case Begin
39226>>>            Case (NavigateData.eNavigateType = nfFromMain)
39228>>>                // If from main, this is a probably a main file Select to Zoom.
39228>>>                // This is the most typical way to navigate to a zoom.
39228>>>                String sInvokingView
39228>>>                Get NamedValueGet NavigateData.NamedValues "fromMain" to sInvokingView
39229>>>                If (sInvokingView = "oSelectEquipo");                    Send ShowInfoBox sInvokingView "Vengo de:"
39232>>>                Case Break
39233>>>                
39233>>>            Case (NavigateData.eNavigateType = nfFromParent)
39236>>>                // If from parent, this is a constrained drill down.
39236>>>                // If needed, you could check NavigateData.iTable to determine the constraining parent.
39236>>>                // This would be unusual - normally you drill down from a parent to a list (Select view).
39236>>>                Case Break
39237>>>                
39237>>>            Case (NavigateData.eNavigateType = nfFromChild)
39240>>>                // If from child, this is a probably a parent Zoom from a Zoom. 
39240>>>                // This is unusual, but it might be used for adding a new child record.
39240>>>                Case Break
39241>>>                
39241>>>            Case Else // must be nfUndefined
39241>>>                // This may be the start of a query or this may be used for some kind of custom operation.
39241>>>                // You may want to check NavigateData.NamedValues.
39241>>>                  
39241>>>        Case End
39241>>>
39241>>>        // Action buttons can be changed dynamically during a Zoom's display lifetime.
39241>>>        // It's best to set these buttons in their own procedure so you can change later.
39241>>>        Send SetActionButtons
