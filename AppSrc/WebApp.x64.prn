39244>>>            Send SetHeaderCaption    ("Equipo:"*equipo.Nombre)
39245>>>            Send SetBreadcrumbCaption equipo.Nombre
39246>>>        End
39246>>>>
39246>>>        Else Begin 
39247>>>            Send SetHeaderCaption     "Nuevo equipo"
39248>>>            Send SetBreadcrumbCaption "Nuevo"
39249>>>        End
39249>>>>
39249>>>    End_Procedure   
