38132>>>        // What to do when the row is selected.
38132>>>        //
38132>>>        // Depending on how you are using this view, you may wish to
38132>>>        // 1. Close the view, which will update the invoking view:
38132>>>        //      Send NavigateClose Self
38132>>>        // 2. Navigate forward to another view (either a from-main Zoom or a from-parent select):
38132>>>        //      Send NavigateForward of oZoomMainView Self
38132>>>        //      Send NavigateForward of oSelectChildView Self
38132>>>        //    Note: Do not forget to register the forward navigation paths using WebRegisterPath
38132>>>        Procedure OnRowClick String sRowID
38135>>>
38135>>>            // If this view is being used in multiple contexts, you may need a block of code
38135>>>            // like this to handle different types of navigation
38135>>>            tWebNavigateData NavigateData
38135>>>            tWebNavigateData NavigateData
38135>>>            Get GetNavigateData to NavigateData
38136>>>            Case Begin
38136>>>                Case (NavigateData.eNavigateType=nfFromParent)
38138>>>                    // If from parent, this is a constrained drilldown.
38138>>>                    // If here, you probably want to Zoom this record or continue to drilldown
38138>>>                    //   (See 2 above). 
38138>>>                    Case Break
38139>>>                Case (NavigateData.eNavigateType=nfFromChild)
38142>>>                    // If from child, this is a probably a parent lookup from a Zoom,
38142>>>                    // so you just want to close (See 1 above)
38142>>>                    Send NavigateClose Self
38143>>>                    Case Break
38144>>>                Case (NavigateData.eNavigateType=nfFromMain)
38147>>>                    // If from main, this is a propbably a main file lookup from a Zoom, 
38147>>>                    // so you just want to close (see 1 above). 
38147>>>                    // This is not used often with the drilldown style
38147>>>                    Send NavigateClose Self
38148>>>                    Case Break
38149>>>                Case Else // must be nfUndefined
38149>>>                    // This may be the start of a drilldown query or some kind of custom query.
38149>>>                    // This could be a NavigateClose or a NaviateForward. You may want to check NavigateData.NamedValues.
38149>>>            Case End
38149>>>        End_Procedure
