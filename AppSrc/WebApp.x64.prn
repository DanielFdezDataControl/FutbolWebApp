41753>>>>>        Set Foreign_Field_Option DD_KEYFIELD    DD_NOPUT        to True
41754>>>>>        Set Foreign_Field_Option DD_KEYFIELD    DD_FINDREQ      to True
41755>>>>>
41755>>>>>        // no permite cambiar el valor en el record
41755>>>>>        Set Foreign_Field_Option DD_INDEXFIELD  DD_NOPUT        to True
41756>>>>>        // hace una búsqueda en la tabla y actualiza los deos, si no la encuentra a null
41756>>>>>        Set Foreign_Field_Option DD_INDEXFIELD  DD_AUTOFIND     to True
41757>>>>>        // busca en la tabla y si no es valor válido o null no lo permite.(null tampoco si no está en autofind también)
41757>>>>>        Set Foreign_Field_Option DD_INDEXFIELD  DD_FINDREQ      to True
41758>>>>>        
41758>>>>>        Set Foreign_Field_Option DD_DEFAULT     DD_DISPLAYONLY  to True
41759>>>>>
41759>>>>>        Set Field_Value_Table Field tablapadre.Sexo to oSexoTablaPadre
