37728>>>    Procedure OnLoad
37731>>>        String sPrevStateHash sView
37731>>>        
37731>>>        Forward Send OnLoad
37733>>>        
37733>>>        //  Store the current state so we can go back to that later (only if it points to a different view)
37733>>>        Get StateHash of ghoWebApp to sPrevStateHash
37734>>>        Send ParseViewStateHash sPrevStateHash (&sView)
37735>>>        If (Lowercase(sView) <> Lowercase(psStateViewName(Self))) Begin
37737>>>            WebSet psPrevStateHash to sPrevStateHash
37738>>>        End
37738>>>>
37738>>>        
37738>>>    End_Procedure
