38211>>>    // Add code to customize your Select View based on how it was invoked.
38211>>>    // Use NavigateData to determine the context this view will be used in.
38211>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
38214>>>        String sQuienEres
38214>>>        // if this view is being used in multiple contexts, you may need a block of code
38214>>>        // like this to handle customizations. This would include hiding rows and buttons
38214>>>        // (WebSet pbRender) and changing the values of various captions.
38214>>>        Case Begin
38214>>>            Case (NavigateData.eNavigateType=nfFromParent)
38216>>>                // If from parent, this is a constrained drill down.
38216>>>                // If needed you could check NavigateData.iTable to determine the constraining parent.
38216>>>                Case Break
38217>>>                
38217>>>            Case (NavigateData.eNavigateType=nfFromChild)
38220>>>                // If from child, this is a probably a parent lookup from a Zoom
38220>>>                Case Break
38221>>>                
38221>>>            Case (NavigateData.eNavigateType=nfFromMain)
38224>>>                // If from main, this is a propbably a main file lookup from a Zoom.
38224>>>                // This is not used often with the drilldown style
38224>>>                Move "Main" to sQuienEres
38225>>>                Case Break
38226>>>                
38226>>>            Case Else // must be nfUndefined
38226>>>                // This may be the start of a drilldown query or some kind ofcustom query.
38226>>>                // You may want to check NavigateData.NamedValues.                 
38226>>>        Case End
38226>>>        
38226>>>        Send SetBreadcrumbCaption "Ligas Selección"
38227>>>        Send SetHeaderCaption     "Ligas"
38228>>>    End_Procedure
38229>>>
38229>>>End_Object
