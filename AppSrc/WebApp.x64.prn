40131>>>    // This can be used to show and hide buttons based on context.
40131>>>    // This can be called any time the view is active.
40131>>>    Procedure SetActionButtons
40134>>>        tWebNavigateData NavigateData
40134>>>        tWebNavigateData NavigateData
40134>>>        Boolean bHasRecord
40134>>>        Handle hoDD
40134>>>
40134>>>        Get Server to hoDD
40135>>>        Get GetNavigateData to NavigateData
40136>>>        
40136>>>        If (hoDD) Begin
40138>>>            Get HasRecord of hoDD to bHasRecord
40139>>>        End
40139>>>>
40139>>>        Else Begin
40140>>>            Move False to bHasRecord
40141>>>        End
40141>>>>
40141>>>
40141>>>        // let's hide all buttons and then show the ones we want
40141>>>        WebSet pbRender of oEditBtn to False 
40142>>>        WebSet pbRender of oSaveBtn to False
40143>>>        WebSet pbRender of oCancelChangesBtn to False
40144>>>        WebSet pbRender of oDeleteBtn to False
40145>>>
40145>>>        If (NavigateData.bReadOnly) Begin 
40147>>>            WebSet pbRender of oEditBtn to True 
40148>>>        End
40148>>>>
40148>>>        Else Begin
40149>>>            WebSet pbRender of oSaveBtn to True
40150>>>            WebSet pbRender of oCancelChangesBtn to True
40151>>>            WebSet pbRender of oDeleteBtn to bHasRecord
40152>>>        End
40152>>>>
40152>>>    End_Procedure
