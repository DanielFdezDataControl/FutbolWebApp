40536>>>    // This can be used to show and hide buttons based on context.
40536>>>    // This can be called any time the view is active.
40536>>>    Procedure SetActionButtons
40539>>>        tWebNavigateData NavigateData
40539>>>        tWebNavigateData NavigateData
40539>>>        Boolean bHasRecord
40539>>>        Handle hoDD
40539>>>
40539>>>        Get Server to hoDD
40540>>>        Get GetNavigateData to NavigateData
40541>>>        
40541>>>        If (hoDD) Begin
40543>>>            Get HasRecord of hoDD to bHasRecord
40544>>>        End
40544>>>>
40544>>>        Else Begin
40545>>>            Move False to bHasRecord
40546>>>        End
40546>>>>
40546>>>
40546>>>        // let's hide all buttons and then show the ones we want
40546>>>        WebSet pbRender of oEditBtn to False 
40547>>>        WebSet pbRender of oSaveBtn to False
40548>>>        WebSet pbRender of oCancelChangesBtn to False
40549>>>        WebSet pbRender of oDeleteBtn to False
40550>>>        
40550>>>        WebSet pbVisible of oPosicionesJugador_btn to False
40551>>>
40551>>>        If (NavigateData.bReadOnly) Begin 
40553>>>            WebSet pbRender of oEditBtn to True 
40554>>>        End
40554>>>>
40554>>>        Else Begin
40555>>>            WebSet pbRender of oSaveBtn to True
40556>>>            WebSet pbRender of oCancelChangesBtn to True
40557>>>            WebSet pbRender of oDeleteBtn to bHasRecord
40558>>>            
40558>>>            WebSet pbVisible of oPosicionesJugador_btn to True
40559>>>        End
40559>>>>
40559>>>    End_Procedure
