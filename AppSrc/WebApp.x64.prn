37330>>>>>Class cWebSessionManagerStandard is a cWebSessionManager
37331>>>>>    
37331>>>>>    Procedure Construct_Object
37333>>>>>        Handle hoObj
37333>>>>>        
37333>>>>>        Forward Send Construct_Object
37335>>>>>        
37335>>>>>        Set pbSessionCookieHttpOnly to True
37336>>>>>        
37336>>>>>        Property Handle phoUserDD 0      // Handle to the WebAppUser DDO
37337>>>>>        Property Handle phoSessionDD 0   // Handle to the WebAppSession DDO  
37338>>>>>        Property Handle phoCrypto 0      // Handle to the PasswordHasher
37339>>>>>        
37339>>>>>        Get CreateNamed (RefClass(cWebAppUserDataDictionary)) 'oUserDD' to hoObj
37340>>>>>        Set phoUserDD to hoObj
37341>>>>>        
37341>>>>>        Get CreateNamed (RefClass(cWebAppSessionDataDictionary)) 'oSessionDD' to hoObj
37342>>>>>        Set DDO_Server of hoObj to (phoUserDD(Self))
37343>>>>>        Set phoSessionDD to hoObj
37344>>>>>        
37344>>>>>        Property Handle phoCrypto 0   // Handle to the Cryptographer
37345>>>>>        Get CreateNamed (RefClass(cPasswordHasher)) 'oCrypto' to hoObj
37346>>>>>        Set phoCrypto to hoObj
37347>>>>>        
37347>>>>>        Property Boolean pbPasswordHashing True
37348>>>>>        
37348>>>>>        Property Boolean pbCreatingNewSession False
37349>>>>>        Property String     psLoginName
37350>>>>>        Property String     psUserName ""
37351>>>>>        Property Integer    piTenantID 0
37352>>>>>        Property Integer    piUserRights 0
37353>>>>>    End_Procedure
37354>>>>>    
37354>>>>>    Procedure End_Construct_Object
37356>>>>>        Forward Send End_Construct_Object
37358>>>>>        
37358>>>>>        Handle hoCrypto
37358>>>>>        Integer iFieldLen
37358>>>>>        If (pbPasswordHashing(Self)) Begin
37360>>>>>            Get phoCrypto to hoCrypto
37361>>>>>            Get_Attribute DF_FIELD_LENGTH of (RefTable(WebAppUser)) (RefTable(WebAppUser.Password)) to iFieldLen
37364>>>>>            If (iFieldLen < (RequiredBufferSize(hoCrypto) + 3)) Begin
37366>>>>>                Error DFERR_PROGRAM "The password field of WebAppUser is not large enough (128)"
37367>>>>>>
37367>>>>>            End
37367>>>>>>
37367>>>>>        End
37367>>>>>>
37367>>>>>    End_Procedure
37368>>>>>    
37368>>>>>    Function CreateSession String sRemoteAddress Returns String
37370>>>>>        String sSessionKey
37370>>>>>        Integer iErr
37370>>>>>        Boolean bLogWebSession
37370>>>>>        Handle hoSessionDD       
37370>>>>>        Get phoSessionDD to hoSessionDD
37371>>>>>        
37371>>>>>        //  Get session key
37371>>>>>        Forward Get CreateSession sRemoteAddress to sSessionKey
37373>>>>>        
37373>>>>>        Get pbLogWebSession to bLogWebSession
37374>>>>>        If not bLogWebSession Begin
37376>>>>>            Function_Return sSessionKey        
37377>>>>>        End
37377>>>>>>
37377>>>>>
37377>>>>>        //  Store session
37377>>>>>        Send Clear of hoSessionDD
37378>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.SessionKey to sSessionKey
37379>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.RemoteAddress to sRemoteAddress
37380>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.Active to "Y"
37381>>>>>        Get Request_Validate of hoSessionDD to iErr
37382>>>>>        If (iErr) Begin
37384>>>>>            // this should not happen. If it does its a programming error
37384>>>>>            Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37385>>>>>>
37385>>>>>            Function_Return ""
37386>>>>>        End
37386>>>>>>
37386>>>>>        Send Request_Save of hoSessionDD
37387>>>>>        If (Err) Begin
37389>>>>>            // this shouldn't happen, if it does likely a duplicate session key issue, even through request_save already gave an error we give another one to make tracking down easier
37389>>>>>            Error DFERR_PROGRAM C_$WebAppSessionSaveFailed
37390>>>>>>
37390>>>>>            Function_Return ""
37391>>>>>        End
37391>>>>>>
37391>>>>>       
37391>>>>>        Function_Return sSessionKey        
37392>>>>>    End_Function
37393>>>>>    
37393>>>>>    Function ValidateSession String sSessionKey Boolean bOptLoadWebApp Returns Boolean
37395>>>>>        DateTime dtLastAccess dtCurrent
37395>>>>>        TimeSpan tsDiff
37395>>>>>        Integer iErr iSessionTimeout iSpanMinutes
37395>>>>>        Boolean bResult bCreatingNewSession
37395>>>>>        Boolean bLogWebSession bLoadWebApp
37395>>>>>        Integer eLoginMode
37395>>>>>        String sTime
37395>>>>>        Handle hoSessionDD hoUserDD       
37395>>>>>        
37395>>>>>        Move False to bLoadWebApp
37396>>>>>        If (num_arguments >= 2) Begin
37398>>>>>            Move bOptLoadWebApp to bLoadWebApp
37399>>>>>        End
37399>>>>>>
37399>>>>>        
37399>>>>>        Get phoSessionDD to hoSessionDD
37400>>>>>        Get phoUserDD to hoUserDD
37401>>>>>        
37401>>>>>        Get pbLogWebSession to bLogWebSession
37402>>>>>        Get peLoginMode to eLoginMode
37403>>>>>        
37403>>>>>        // for this object, you can only disable logging if login completely is disabled
37403>>>>>        If (not(bLogWebSession) and (eLoginMode<>lmLoginNone)) Begin
37405>>>>>            Error DFERR_PROGRAM C_$WebSessionLoggingMustBeEnabled
37406>>>>>>
37406>>>>>            Function_Return False
37407>>>>>        End
37407>>>>>>
37407>>>>>
37407>>>>>        //  Clear session properties
37407>>>>>        Set psSessionKey to ""
37408>>>>>        Send UpdateSessionProperties True
37409>>>>>        
37409>>>>>        If not bLogWebSession Begin
37411>>>>>            Forward Get ValidateSession sSessionKey to bResult
37413>>>>>            Function_Return bResult
37414>>>>>        End        
37414>>>>>>
37414>>>>>        
37414>>>>>        Move False to bResult
37415>>>>>        Get piSessionTimeout to iSessionTimeout 
37416>>>>>        
37416>>>>>        //  Check if session exists
37416>>>>>        Send Clear of hoSessionDD
37417>>>>>        Move sSessionKey to WebAppSession.SessionKey
37418>>>>>        Send Find of hoSessionDD EQ Index.1
37419>>>>>            
37419>>>>>        If (Found) Begin
37421>>>>>            //  Calculate timespan between now and last access time
37421>>>>>            Move (CurrentDateTime()) to dtCurrent
37422>>>>>            Move WebAppSession.LastAccessDate to dtLastAccess
37423>>>>>            Get StringToTime of hoSessionDD dtLastAccess WebAppSession.LastAccessTime to dtLastAccess
37424>>>>>            Move (dtCurrent - dtLastAccess) to tsDiff
37425>>>>>            Move (SpanTotalMinutes(tsDiff)) to iSpanMinutes
37426>>>>>            
37426>>>>>            //  Check if session didn't time out
37426>>>>>            If (IsDateValid(dtLastAccess) and (iSessionTimeout <= 0 or (iSpanMinutes < iSessionTimeout)) and WebAppSession.Active = "Y") Begin
37428>>>>>                Forward Get ValidateSession sSessionKey to bResult
37430>>>>>                   
37430>>>>>                If (bResult) Begin
37432>>>>>                    //  Update session record
37432>>>>>                    Get TimeToString of hoSessionDD dtCurrent to sTime 
37433>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessDate to dtCurrent
37434>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessTime to sTime
37435>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.UseCount to (WebAppSession.UseCount + 1)
37436>>>>>                    Get Request_Validate of hoSessionDD to iErr
37437>>>>>                    If (iErr) Begin
37439>>>>>                        // this should not happen. If it does its a programming error
37439>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37440>>>>>>
37440>>>>>                        Function_Return False
37441>>>>>                    End
37441>>>>>>
37441>>>>>                    Send Request_Save of hoSessionDD
37442>>>>>                    
37442>>>>>                    //  Update user properties
37442>>>>>                    Send UpdateSessionProperties False
37443>>>>>                End
37443>>>>>>
37443>>>>>            End
37443>>>>>>
37443>>>>>            Else Begin
37444>>>>>                // Test the Creating New Session Flag to protect against infinite recursion....
37444>>>>>                Get pbCreatingNewSession to bCreatingNewSession
37445>>>>>                
37445>>>>>                If (not(bCreatingNewSession)) Begin
37447>>>>>                    If (not(bLoadWebApp)) Begin
37449>>>>>                        Move False to bResult   //  We can only continue immediately if we were loading the webapp, other operations are not allowed!
37450>>>>>                        Error DFERR_WEBAPP_SESSION_TIMEOUT "Your application session has timed out or is inactive, please login again."
37451>>>>>>
37451>>>>>                        Send NavigateRefresh of ghoWebApp          // refresh the WebApp at the client (triggers a login)
37452>>>>>                    End
37452>>>>>>
37452>>>>>                    Else Begin
37453>>>>>                        Set pbCreatingNewSession to True                    
37454>>>>>                        Get RecreateSession of ghoWebApp to bResult 
37455>>>>>                        Set pbCreatingNewSession to False                        
37456>>>>>                    End
37456>>>>>>
37456>>>>>                End
37456>>>>>>
37456>>>>>            End
37456>>>>>>
37456>>>>>        End
37456>>>>>>
37456>>>>>        Else Begin
37457>>>>>            Error DFERR_WEBAPP_BAD_SESSION_KEY "Session key not known (reload page to recreate session)"
37458>>>>>>
37458>>>>>        End
37458>>>>>>
37458>>>>>        
37458>>>>>        Function_Return bResult
37459>>>>>    End_Function
37460>>>>>    
37460>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
37462>>>>>        If (not(pbPasswordHashing(Self))) Begin
37464>>>>>            Move sPassword to sHash
37465>>>>>            Function_Return True
37466>>>>>        End
37466>>>>>>
37466>>>>>        
37466>>>>>        If (not(CreatePasswordHash(phoCrypto(Self), sPassword, &sHash))) Begin
37468>>>>>            Function_Return False
37469>>>>>        End
37469>>>>>>
37469>>>>>        Move ("V1$" + sHash) to sHash
37470>>>>>        Function_Return True
37471>>>>>    End_Function
37472>>>>>    
37472>>>>>    Function VerifyPasswordHash String sUserPassword String sEnteredPassword Boolean ByRef bShouldUpgrade Returns Boolean
37474>>>>>        If (not(pbPasswordHashing(Self))) Begin
37476>>>>>            Move False to bShouldUpgrade
37477>>>>>            Function_Return (sUserPassword = sEnteredPassword)
37478>>>>>        End
37478>>>>>>
37478>>>>>        
37478>>>>>        String sVersion
37478>>>>>        Move (Left(sUserPassword, 3)) to sVersion
37479>>>>>        If (sVersion = "V1$") Begin
37481>>>>>            If (num_arguments > 2) Move False to bShouldUpgrade
37484>>>>>            Function_Return (VerifyPasswordHash(phoCrypto(Self), sEnteredPassword, Right(sUserPassword, Length(sUserPassword) - 3)))
37485>>>>>        End
