40509>>>        Integer iMiTabla iMiCol
40509>>>        Move (NavigateData.sRowID) to sRowID
40510>>>        Move (NavigateData.iTable) to iMiTabla
40511>>>        Move (NavigateData.iColumn) to iMiCol
40512>>>        
40512>>>        //------
40512>>>    End_Procedure
