38239>>>
38239>>>        // What to do when the row is selected.
38239>>>        //
38239>>>        // Depending on how you are using this view, you may wish to
38239>>>        // 1. Close the view, which will update the invoking view:
38239>>>        //      Send NavigateClose Self
38239>>>        // 2. Navigate forward to another view (either a from-main Zoom or a from-parent select):
38239>>>        //      Send NavigateForward of oZoomMainView Self
38239>>>        //      Send NavigateForward of oSelectChildView Self
38239>>>        //    Note: Do not forget to register the forward navigation paths using WebRegisterPath
38239>>>        Procedure OnRowClick String sRowID
38242>>>
38242>>>            // If this view is being used in multiple contexts, you may need a block of code
38242>>>            // like this to handle different types of navigation
38242>>>            tWebNavigateData NavigateData
38242>>>            tWebNavigateData NavigateData
38242>>>            Get GetNavigateData to NavigateData
38243>>>            Case Begin
38243>>>                Case (NavigateData.eNavigateType=nfFromParent)
38245>>>                    // If from parent, this is a constrained drilldown.
38245>>>                    // If here, you probably want to Zoom this record or continue to drilldown
38245>>>                    //   (See 2 above). 
38245>>>                    Case Break
38246>>>                Case (NavigateData.eNavigateType=nfFromChild)
38249>>>                    // If from child, this is a probably a parent lookup from a Zoom,
38249>>>                    // so you just want to close (See 1 above)
38249>>>                    Send NavigateClose Self
38250>>>                    Case Break
38251>>>                Case (NavigateData.eNavigateType=nfFromMain)
38254>>>                    // If from main, this is a propbably a main file lookup from a Zoom, 
38254>>>                    // so you just want to close (see 1 above). 
38254>>>                    // This is not used often with the drilldown style
38254>>>                    Send NavigateClose Self
38255>>>                    Case Break
38256>>>                Case Else // must be nfUndefined
38256>>>                    // This may be the start of a drilldown query or some kind of custom query.
38256>>>                    // This could be a NavigateClose or a NaviateForward. You may want to check NavigateData.NamedValues.
38256>>>            Case End
38256>>>        End_Procedure
