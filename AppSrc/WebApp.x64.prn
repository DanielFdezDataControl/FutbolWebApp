39703>>>    // This can be used to show and hide buttons based on context.
39703>>>    // This can be called any time the view is active.
39703>>>    Procedure SetActionButtons
39706>>>        tWebNavigateData NavigateData
39706>>>        tWebNavigateData NavigateData
39706>>>        Boolean bHasRecord
39706>>>        Handle hoDD
39706>>>
39706>>>        Get Server to hoDD
39707>>>        Get GetNavigateData to NavigateData
39708>>>        
39708>>>        If (hoDD) Begin
39710>>>            Get HasRecord of hoDD to bHasRecord
39711>>>        End
39711>>>>
39711>>>        Else Begin
39712>>>            Move False to bHasRecord
39713>>>        End
39713>>>>
39713>>>
39713>>>        // let's hide all buttons and then show the ones we want
39713>>>        WebSet pbRender of oEditBtn to False 
39714>>>        WebSet pbRender of oSaveBtn to False
39715>>>        WebSet pbRender of oCancelChangesBtn to False
39716>>>        WebSet pbRender of oDeleteBtn to False
39717>>>
39717>>>        If (NavigateData.bReadOnly) Begin 
39719>>>            WebSet pbRender of oEditBtn to True 
39720>>>        End
39720>>>>
39720>>>        Else Begin
39721>>>            WebSet pbRender of oSaveBtn to True
39722>>>            WebSet pbRender of oCancelChangesBtn to True
39723>>>            WebSet pbRender of oDeleteBtn to bHasRecord
39724>>>        End
39724>>>>
39724>>>    End_Procedure
39725>>>
