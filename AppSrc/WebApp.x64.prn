37067>>>>>>>        // Handle Optionals
37067>>>>>>>        // First the optional throwing of errors.
37067>>>>>>>        Boolean bThrow
37067>>>>>>>        Move True to bThrow
37068>>>>>>>        If (num_arguments > 4) Move bOptThrow to bThrow
37071>>>>>>>        
37071>>>>>>>        // Open the algorithm.
37071>>>>>>>        Handle hoProv
37071>>>>>>>        Move (CNG_BCryptOpenAlgorithmProvider(AddressOf(hoProv), AddressOf(wsAlgo), 0, |CI$00000008 /*BCRYPT_ALG_HANDLE_HMAC_FLAG*/)) to iErr
37072>>>>>>>        If (iErr) Begin
37074>>>>>>>            If (bThrow) Error 8710 "Failed to open up the algo provider."
37077>>>>>>>            Function_Return False
37078>>>>>>>        End
37078>>>>>>>>
37078>>>>>>>        
37078>>>>>>>        Get CNG_PBKDF2_HMAC_BufferSizeEx hoProv to iHashLen
37079>>>>>>>        If (not(iHashLen)) Begin
37081>>>>>>>            If (bThrow) Error 8710 "Failed to get expected length of hash."
37084>>>>>>>            Function_Return False
37085>>>>>>>        End
37085>>>>>>>>
37085>>>>>>>        
37085>>>>>>>        // Resize buffers to the expected output.
37085>>>>>>>        Move (ResizeArray(ucaHashOut, iHashLen)) to ucaHashOut
37086>>>>>>>        
37086>>>>>>>        Move (CNG_BCryptDeriveKeyPBKDF2(hoProv, AddressOf(ucaData), SizeOfArray(ucaData), AddressOf(ucaSalt), SizeOfArray(ucaSalt), uiTimeCost, AddressOf(ucaHashOut), SizeOfArray(ucaHashOut), 0)) to iErr
37087>>>>>>>        If (iErr) Begin
37089>>>>>>>            Move (CNG_BCryptCloseAlgorithmProvider(hoProv, 0)) to iErr
37090>>>>>>>            If (bThrow) Error 8710 "Failed to create hash."
37093>>>>>>>            Function_Return False
37094>>>>>>>        End
37094>>>>>>>>
37094>>>>>>>        
37094>>>>>>>        Move (CNG_BCryptCloseAlgorithmProvider(hoProv, 0)) to iErr
37095>>>>>>>        If (iErr) Begin
37097>>>>>>>            If (bThrow) Error 8710 "Failed to close algo provider."
37100>>>>>>>            Function_Return False
37101>>>>>>>        End
37101>>>>>>>>
37101>>>>>>>        
37101>>>>>>>        Function_Return True
37102>>>>>>>    End_Function
37103>>>>>>>End_Class
