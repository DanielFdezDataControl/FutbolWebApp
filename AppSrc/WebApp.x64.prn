37767>>>    Procedure OnLoad
37770>>>        String sPrevStateHash sView
37770>>>        
37770>>>        Forward Send OnLoad
37772>>>        
37772>>>        //  Store the current state so we can go back to that later (only if it points to a different view)
37772>>>        Get StateHash of ghoWebApp to sPrevStateHash
37773>>>        Send ParseViewStateHash sPrevStateHash (&sView)
37774>>>        If (Lowercase(sView) <> Lowercase(psStateViewName(Self))) Begin
37776>>>            WebSet psPrevStateHash to sPrevStateHash
37777>>>        End
37777>>>>
37777>>>        
37777>>>    End_Procedure
