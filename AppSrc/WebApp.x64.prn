38238>>>>>Class cequipoDataDictionary is a DataDictionary
38239>>>>>    
38239>>>>>    Procedure Construct_Object
38241>>>>>        Forward Send Construct_Object
38243>>>>>        Set Main_File to equipo.File_Number
38244>>>>>
38244>>>>>        Set Key_Field_State Field equipo.ID to True
38245>>>>>        
38245>>>>>        Set Add_Server_File to liga.File_Number
38246>>>>>
38246>>>>>        Set Add_Client_File to entrenador.File_Number
38247>>>>>        Set Add_Client_File to jugador.File_Number
38248>>>>>
38248>>>>>        Set Foreign_Field_Option DD_KEYFIELD DD_NOPUT       to True
38249>>>>>        Set Foreign_Field_Option DD_KEYFIELD DD_FINDREQ     to True
38250>>>>>       
38250>>>>>        Set Foreign_Field_Option DD_INDEXFIELD DD_NOPUT     to True
38251>>>>>        
38251>>>>>        Set Foreign_Field_Option DD_DEFAULT DD_DISPLAYONLY  to True
38252>>>>>               
38252>>>>>    End_Procedure
38253>>>>>
38253>>>>>    // 1
38253>>>>>    Procedure Backout
38255>>>>>        Forward Send Backout
38257>>>>>        
38257>>>>>        Integer iNumEquipos
38257>>>>>        
38257>>>>>        Move liga.Equipos       to iNumEquipos
38258>>>>>        
38258>>>>>        If (iNumEquipos > 0) Begin
38260>>>>>            Decrement iNumEquipos
38261>>>>>            Move iNumEquipos to liga.Equipos            
38262>>>>>        End
38262>>>>>>
38262>>>>>        Else Begin
38263>>>>>            Send UserError "No hay equipos para quitar" "ERROR"
38264>>>>>        End               
38264>>>>>>
38264>>>>>    End_Procedure
38265>>>>>    
38265>>>>>    // 2
38265>>>>>    Procedure Update
38267>>>>>        Forward Send Update
38269>>>>>        
38269>>>>>        Integer iNumEquipos iMaxEquipos
38269>>>>>        
38269>>>>>        Move liga.Equipos       to iNumEquipos
38270>>>>>        Move liga.EquiposMax    to iMaxEquipos
38271>>>>>        
38271>>>>>        If (iNumEquipos < iMaxEquipos) Begin
38273>>>>>            Increment iNumEquipos
38274>>>>>            Move iNumEquipos to liga.Equipos            
38275>>>>>        End
38275>>>>>>
38275>>>>>        Else Begin
38276>>>>>            Send UserError "No hay sitio en la liga para el nuevo equipo" "ERROR"           
38277>>>>>        End
38277>>>>>>
38277>>>>>    End_Procedure       
38278>>>>>End_Class
