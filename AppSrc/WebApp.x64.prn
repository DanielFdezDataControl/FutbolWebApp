37517>>>>>    Function UserLogin String sLoginName Integer iTenantID String sPassword Returns Boolean
37519>>>>>        String  sSessionKey sUserPassword
37519>>>>>        Handle  hoSessionDD hoUserDD
37519>>>>>        Boolean bMatch bUpgrade
37519>>>>>        
37519>>>>>        Get phoSessionDD to hoSessionDD
37520>>>>>        Get phoUserDD to hoUserDD
37521>>>>>        Integer iErr eLoginMode
37521>>>>>        
37521>>>>>        // Refind session record
37521>>>>>        Get psSessionKey to sSessionKey
37522>>>>>        Send Clear of hoSessionDD
37523>>>>>        Move sSessionKey to WebAppSession.SessionKey
37524>>>>>        Send Find of hoSessionDD EQ Index.1
37525>>>>>        
37525>>>>>        If (Found and WebAppSession.SessionKey = sSessionKey) Begin
37527>>>>>            Get peLoginMode to eLoginMode
37528>>>>>            
37528>>>>>            //  Find the user
37528>>>>>            Move sLoginName to WebAppUser.LoginName
37529>>>>>            Move iTenantID  to WebAppUser.TenantID
37530>>>>>            Send Find of hoUserDD GE Index.2
37531>>>>>            
37531>>>>>            // Check username and password
37531>>>>>            If (Found and (Lowercase(sLoginName) = Lowercase(Trim(WebAppUser.LoginName))) and (iTenantID = WebAppUser.TenantID)) Begin
37533>>>>>                Get Field_Current_Value of hoUserDD Field WebAppUser.Password to sUserPassword
37534>>>>>                Get VerifyPasswordHash (Trim(sUserPassword)) (Trim(sPassword)) (&bUpgrade) to bMatch
37535>>>>>                
37535>>>>>                If (bMatch) Begin
37537>>>>>                    // Store the login
37537>>>>>                    If (bUpgrade) Begin
37539>>>>>                        Get CreatePasswordHash (Trim(sPassword)) (&sPassword) to bUpgrade
37540>>>>>                        If (bUpgrade) Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37543>>>>>                    End
37543>>>>>>
37543>>>>>                    Set Field_Changed_Value of hoUserDD Field WebAppUser.LastLogin to (CurrentDateTime())
37544>>>>>                    Get Request_Validate of hoSessionDD to iErr
37545>>>>>                    If (iErr) Begin
37547>>>>>                        // this should not happen. If it does its a programming error
37547>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37548>>>>>>
37548>>>>>                        Function_Return False
37549>>>>>                    End
37549>>>>>>
37549>>>>>                    
37549>>>>>                    Send Request_Save of hoSessionDD
37550>>>>>                    
37550>>>>>                    // Update session properties
37550>>>>>                    Send UpdateSessionProperties False
37551>>>>>                    Send NotifyChangeRights
37552>>>>>                    Function_Return True
37553>>>>>                End
37553>>>>>>
37553>>>>>                Else Begin
37554>>>>>                    //  We should rely directly on this buffer elsewhere but just be sure
37554>>>>>                    Send Clear of hoUserDD
37555>>>>>                End
37555>>>>>>
37555>>>>>            End
37555>>>>>>
37555>>>>>            Else Begin
37556>>>>>                // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37556>>>>>                Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37557>>>>>            End
37557>>>>>>
37557>>>>>        End
37557>>>>>>
37557>>>>>        Else Begin
37558>>>>>            // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37558>>>>>            Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37559>>>>>        End
37559>>>>>>
37559>>>>>          
37559>>>>>        Function_Return False
37560>>>>>    End_Function
