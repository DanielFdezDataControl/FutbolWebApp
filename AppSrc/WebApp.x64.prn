38612>>>    // This can be used to show and hide buttons based on context.
38612>>>    // This can be called any time the view is active.
38612>>>    Procedure SetActionButtons
38615>>>        tWebNavigateData NavigateData
38615>>>        tWebNavigateData NavigateData
38615>>>        Boolean bHasRecord
38615>>>        Handle hoDD
38615>>>
38615>>>        Get Server to hoDD
38616>>>
38616>>>        Get GetNavigateData to NavigateData
38617>>>        
38617>>>        If (hoDD) Begin
38619>>>            Get HasRecord of hoDD to bHasRecord
38620>>>        End
38620>>>>
38620>>>        Else Begin
38621>>>            Move False to bHasRecord
38622>>>        End
38622>>>>
38622>>>
38622>>>        // let's hide all buttons and then show the ones we want
38622>>>        WebSet pbRender of oEditBtn to False 
38623>>>        WebSet pbRender of oSaveBtn to False
38624>>>        WebSet pbRender of oCancelChangesBtn to False
38625>>>        WebSet pbRender of oDeleteBtn to False
38626>>>
38626>>>        If (NavigateData.bReadOnly) Begin 
38628>>>            WebSet pbRender of oEditBtn to True 
38629>>>        End
38629>>>>
38629>>>        Else Begin
38630>>>            WebSet pbRender of oSaveBtn to True
38631>>>            WebSet pbRender of oCancelChangesBtn to True
38632>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38633>>>        End
38633>>>>
38633>>>    End_Procedure
