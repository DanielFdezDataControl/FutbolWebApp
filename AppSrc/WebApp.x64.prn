38321>>>    // Add code to customize your Select View based on how it was invoked.
38321>>>    // Use NavigateData to determine the context this view will be used in.
38321>>>    
38321>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
38324>>>        // evento de LLEGADA 
38324>>>        // este evento es de la VISTA
38324>>>        String sQuienEres
38324>>>        // if this view is being used in multiple contexts, you may need a block of code
38324>>>        // like this to handle customizations. This would include hiding rows and buttons
38324>>>        // (WebSet pbRender) and changing the values of various captions.
38324>>>        Case Begin
38324>>>            Case (NavigateData.eNavigateType=nfFromParent)
38326>>>                // If from parent, this is a constrained drill down.
38326>>>                // If needed you could check NavigateData.iTable to determine the constraining parent.
38326>>>                Case Break
38327>>>                
38327>>>            Case (NavigateData.eNavigateType=nfFromChild)
38330>>>                // If from child, this is a probably a parent lookup from a Zoom
38330>>>                
38330>>>                Case Break
38331>>>                
38331>>>            Case (NavigateData.eNavigateType=nfFromMain)
38334>>>                // If from main, this is a propbably a main file lookup from a Zoom.
38334>>>                // This is not used often with the drilldown style
38334>>>                Move "Main" to sQuienEres
38335>>>                Case Break
38336>>>                
38336>>>            Case Else // must be nfUndefined
38336>>>                // This may be the start of a drilldown query or some kind ofcustom query.
38336>>>                // You may want to check NavigateData.NamedValues.                 
38336>>>        Case End
38336>>>        
38336>>>        Send SetBreadcrumbCaption "Ligas Selección"
38337>>>        Send SetHeaderCaption     "Ligas"
38338>>>        
38338>>>    End_Procedure
