38368>>>>>Class cequipoDataDictionary is a DataDictionary
38369>>>>>    
38369>>>>>    Procedure Construct_Object
38371>>>>>        Forward Send Construct_Object
38373>>>>>        Set Main_File to equipo.File_Number
38374>>>>>
38374>>>>>        Set Key_Field_State Field equipo.ID to True
38375>>>>>        
38375>>>>>        Set Add_Server_File to liga.File_Number
38376>>>>>
38376>>>>>        Set Add_Client_File to entrenador.File_Number
38377>>>>>        Set Add_Client_File to jugador.File_Number
38378>>>>>
38378>>>>>        Set Foreign_Field_Option DD_KEYFIELD DD_NOPUT       to True
38379>>>>>        Set Foreign_Field_Option DD_KEYFIELD DD_FINDREQ     to True
38380>>>>>       
38380>>>>>        Set Foreign_Field_Option DD_INDEXFIELD DD_NOPUT     to True
38381>>>>>        
38381>>>>>        Set Foreign_Field_Option DD_DEFAULT DD_DISPLAYONLY  to True
38382>>>>>               
38382>>>>>    End_Procedure
38383>>>>>
38383>>>>>    // 1
38383>>>>>    Procedure Backout
38385>>>>>        Forward Send Backout
38387>>>>>        
38387>>>>>        Integer iNumEquipos
38387>>>>>        
38387>>>>>        Move liga.Equipos       to iNumEquipos
38388>>>>>        
38388>>>>>        If (iNumEquipos > 0) Begin
38390>>>>>            Decrement iNumEquipos
38391>>>>>            Move iNumEquipos to liga.Equipos            
38392>>>>>        End
38392>>>>>>
38392>>>>>        Else Begin
38393>>>>>            Send UserError "No hay equipos para quitar" "ERROR"
38394>>>>>        End               
38394>>>>>>
38394>>>>>    End_Procedure
38395>>>>>    
38395>>>>>    // 2
38395>>>>>    Procedure Update
38397>>>>>        Forward Send Update
38399>>>>>        
38399>>>>>        Integer iNumEquipos iMaxEquipos
38399>>>>>        
38399>>>>>        Move liga.Equipos       to iNumEquipos
38400>>>>>        Move liga.EquiposMax    to iMaxEquipos
38401>>>>>        
38401>>>>>        If (iNumEquipos < iMaxEquipos) Begin
38403>>>>>            Increment iNumEquipos
