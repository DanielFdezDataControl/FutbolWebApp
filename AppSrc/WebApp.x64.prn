37101>>>>>>>                Get CNG_PBKDF2_HMAC "SHA256" (StringToUCharArray(sPassword)) ucaSalt uiOptTimeCost (&ucaHash) False to bOk
37102>>>>>>>                If (not(bOk)) Function_Return False
37105>>>>>>>                
37105>>>>>>>                Move True to bRequireTimeCost
37106>>>>>>>                Case Break
37107>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
37110>>>>>>>                Get CNG_PBKDF2_HMAC "SHA512" (StringToUCharArray(sPassword)) ucaSalt uiOptTimeCost (&ucaHash) False to bOk
37111>>>>>>>                If (not(bOk)) Function_Return False
37114>>>>>>>                
37114>>>>>>>                Move True to bRequireTimeCost
37115>>>>>>>                Case Break
37116>>>>>>>            Case Else
37116>>>>>>>                Error 8710 "Invalid algorithm selected."
37117>>>>>>>>
37117>>>>>>>                Function_Return False
37118>>>>>>>        Case End
37118>>>>>>>        
37118>>>>>>>        String sSalt
