40389>>>    // Add code to customize your Select View based on how it was invoked.
40389>>>    // Use NavigateData to determine the context this view will be used in.
40389>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
40392>>>
40392>>>        // if this view is being used in multiple contexts, you may need a block of code
40392>>>        // like this to handle customizations. This would include hiding rows and buttons
40392>>>        // (WebSet pbRender) and changing the values of various captions.
40392>>>        
40392>>>        String sDesdeDondeVengo
40392>>>        Case Begin
40392>>>            Case (NavigateData.eNavigateType=nfFromParent)
40394>>>                // If from parent, this is a constrained drill down.
40394>>>                // If needed you could check NavigateData.iTable to determine the constraining parent.
40394>>>                Move "Padre" to sDesdeDondeVengo
40395>>>                Case Break
40396>>>                
40396>>>            Case (NavigateData.eNavigateType=nfFromChild)
40399>>>                // If from child, this is a probably a parent lookup from a Zoom
40399>>>                Move "Hijo" to sDesdeDondeVengo
40400>>>                Case Break
40401>>>                
40401>>>            Case (NavigateData.eNavigateType=nfFromMain)
40404>>>                // If from main, this is a propbably a main file lookup from a Zoom.
40404>>>                // This is not used often with the drilldown style
40404>>>                Move "Hermano" to sDesdeDondeVengo
40405>>>                Case Break
40406>>>                
40406>>>            Case Else // must be nfUndefined
40406>>>                // This may be the start of a drilldown query or some kind ofcustom query.
40406>>>                // You may want to check NavigateData.NamedValues.
40406>>>                  
40406>>>        Case End
40406>>>            
40406>>>        Send SetHeaderCaption    ("Posiciones de:"*Jugador.Nombre*jugador.Apellido)
40407>>>        Send SetBreadcrumbCaption ("Sus posiciones")     
40408>>>        
40408>>>        Send RefreshListFromDD of oPosicionesTotales_List
40409>>>        
40409>>>        //------
40409>>>        String sRowID
40409>>>        Integer iMiTabla iMiCol
40409>>>        Move (NavigateData.sRowID) to sRowID
40410>>>        Move (NavigateData.iTable) to iMiTabla
40411>>>        Move (NavigateData.iColumn) to iMiCol
40412>>>        
40412>>>        //------
40412>>>    End_Procedure
40413>>>
40413>>>End_Object
