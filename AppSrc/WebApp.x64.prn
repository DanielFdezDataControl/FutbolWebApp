37126>>>>>>>    End_Enum_List
37126>>>>>>>    
37126>>>>>>>    Function RandomBuffer UInteger uiSize Returns UChar[]
37128>>>>>>>        UChar[] ucaBuffer
37129>>>>>>>        Move (ResizeArray(ucaBuffer, uiSize)) to ucaBuffer
37130>>>>>>>        If (CNG_BCryptGenRandom(0, AddressOf(ucaBuffer), uiSize, |CI$00000002 /*BCRYPT_USE_SYSTEM_PREFERRED_RNG*/)) Begin
37132>>>>>>>            Error 8710 "Failed to create random buffer."
37133>>>>>>>>
37133>>>>>>>        End
37133>>>>>>>>
37133>>>>>>>        Function_Return ucaBuffer
37134>>>>>>>    End_Function
37135>>>>>>>    
37135>>>>>>>    Function Base64EncodeArr UChar[] ucaBuffer Returns String
37137>>>>>>>        Integer iErr
37137>>>>>>>        Pointer pBase64
37137>>>>>>>        String sBase64
37137>>>>>>>        Move (Base64Encode(AddressOf(ucaBuffer), SizeOfArray(ucaBuffer))) to pBase64
37138>>>>>>>        If (not(pBase64)) Begin
37140>>>>>>>            Function_Return sBase64
37141>>>>>>>        End
37141>>>>>>>>
37141>>>>>>>        Move (PointerToString(pBase64)) to sBase64
37142>>>>>>>        Move (Free(pBase64)) to iErr
37143>>>>>>>        Function_Return sBase64
37144>>>>>>>    End_Function
37145>>>>>>>    
37145>>>>>>>    Function Base64DecodeArr String sBase64 Returns UChar[]
37147>>>>>>>        Integer iLen
37147>>>>>>>        Pointer pBase64
37147>>>>>>>        UChar[] ucaBuffer
37148>>>>>>>        Move (Base64Decode(AddressOf(sBase64), &iLen)) to pBase64
37149>>>>>>>        If (not(pBase64)) Begin
37151>>>>>>>            Function_Return ucaBuffer
37152>>>>>>>        End
37152>>>>>>>>
37152>>>>>>>        
37152>>>>>>>        Move (ResizeArray(ucaBuffer, iLen)) to ucaBuffer
37153>>>>>>>        Move (MemCopy(AddressOf(ucaBuffer), pBase64, iLen)) to iLen
37154>>>>>>>        Move (Free(pBase64)) to iLen
37155>>>>>>>        Function_Return ucaBuffer
37156>>>>>>>    End_Function
37157>>>>>>>    
37157>>>>>>>    Function CreatePasswordHashExWithSalt UInteger uiAlgo UChar[] ucaSalt String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
37159>>>>>>>        Boolean bOk bRequireTimeCost
37159>>>>>>>        UChar[] ucaHash
37160>>>>>>>        
37160>>>>>>>        Case Begin
37160>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
37162>>>>>>>                Get CNG_PBKDF2_HMAC "SHA256" (StringToUCharArray(sPassword)) ucaSalt uiOptTimeCost (&ucaHash) False to bOk
37163>>>>>>>                If (not(bOk)) Function_Return False
37166>>>>>>>                
37166>>>>>>>                Move True to bRequireTimeCost
37167>>>>>>>                Case Break
37168>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
37171>>>>>>>                Get CNG_PBKDF2_HMAC "SHA512" (StringToUCharArray(sPassword)) ucaSalt uiOptTimeCost (&ucaHash) False to bOk
37172>>>>>>>                If (not(bOk)) Function_Return False
37175>>>>>>>                
37175>>>>>>>                Move True to bRequireTimeCost
37176>>>>>>>                Case Break
37177>>>>>>>            Case Else
37177>>>>>>>                Error 8710 "Invalid algorithm selected."
37178>>>>>>>>
37178>>>>>>>                Function_Return False
37179>>>>>>>        Case End
37179>>>>>>>        
37179>>>>>>>        String sSalt
37179>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
37180>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return False
37183>>>>>>>        Get Base64EncodeArr ucaHash to sHash
37184>>>>>>>        If (not(SizeOfString(sHash))) Function_Return False
37187>>>>>>>        
37187>>>>>>>        If (bRequireTimeCost) Begin
37189>>>>>>>            Move (SFormat("%1$%2$%3$%4",            ;                            String(uiAlgo),         ;                            sSalt,                  ;                            String(uiOptTimeCost),  ;                            sHash)) to sHash
37190>>>>>>>        End
37190>>>>>>>>
37190>>>>>>>        Else Begin
37191>>>>>>>            Move (SFormat("%1$%2$%3",               ;                            String(uiAlgo),         ;                            sSalt,                  ;                            sHash)) to sHash
37192>>>>>>>        End
37192>>>>>>>>
37192>>>>>>>        
37192>>>>>>>        Function_Return bOk
37193>>>>>>>    End_Function
37194>>>>>>>    
37194>>>>>>>    Function CreatePasswordHashEx UInteger uiAlgo UInteger uiSaltSize String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
37196>>>>>>>        UChar[] ucaSalt
37197>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
37198>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
37201>>>>>>>        
37201>>>>>>>        If (num_arguments > 4) Begin
37203>>>>>>>            Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash, uiOptTimeCost))
37204>>>>>>>        End
37204>>>>>>>>
37204>>>>>>>        Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash))
37205>>>>>>>    End_Function
37206>>>>>>>    
37206>>>>>>>    Function VerifyPasswordHash String sPassword String sHash Returns Boolean
37208>>>>>>>        Boolean bRequiresTimeCost
37208>>>>>>>        UInteger uiAlgo uiTimeCost
37208>>>>>>>        Integer iBegin iEnd
37208>>>>>>>        String sSalt
37208>>>>>>>        
37208>>>>>>>        Move 1 to iBegin
37209>>>>>>>        
37209>>>>>>>        // Parse Algo
37209>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
37210>>>>>>>        If (not(iEnd)) Function_Return False
37213>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiAlgo
37214>>>>>>>        
37214>>>>>>>        // Parse Salt
37214>>>>>>>        Move (iEnd + 1) to iBegin
37215>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
37216>>>>>>>        If (not(iEnd)) Function_Return False
37219>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to sSalt
37220>>>>>>>        
37220>>>>>>>        Case Begin
37220>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
37222>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
37225>>>>>>>                Move True to bRequiresTimeCost
37226>>>>>>>                Case Break
37227>>>>>>>            Case Else
37227>>>>>>>                Error 8710 "Invalid algorithm selected."
37228>>>>>>>>
37228>>>>>>>                Function_Return False
37229>>>>>>>        Case End
37229>>>>>>>        
37229>>>>>>>        // Parse optional timecost
37229>>>>>>>        If (bRequiresTimeCost) Begin
37231>>>>>>>            Move (iEnd + 1) to iBegin
37232>>>>>>>            Move (Pos("$", sHash, iBegin)) to iEnd
37233>>>>>>>            If (not(iEnd)) Function_Return False
37236>>>>>>>            Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiTimeCost
37237>>>>>>>        End
37237>>>>>>>>
37237>>>>>>>        
37237>>>>>>>        // Parse rest hash
37237>>>>>>>        Move (iEnd + 1) to iBegin
37238>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
37239>>>>>>>        If (iEnd) Function_Return False // inverse check if there are any other errors.
37242>>>>>>>        
37242>>>>>>>        // Base64Decode
37242>>>>>>>        UChar[] ucaSalt
37243>>>>>>>        Get Base64DecodeArr sSalt to ucaSalt
37244>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
37247>>>>>>>        
37247>>>>>>>        // Create new hash
37247>>>>>>>        String sNewHash
37247>>>>>>>        If (bRequiresTimeCost) Begin
37249>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash, uiTimeCost))) Begin
37251>>>>>>>                Function_Return False 
37252>>>>>>>            End
37252>>>>>>>>
37252>>>>>>>        End
37252>>>>>>>>
37252>>>>>>>        Else Begin
37253>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash))) Begin
37255>>>>>>>                Function_Return False 
37256>>>>>>>            End
37256>>>>>>>>
37256>>>>>>>        End
37256>>>>>>>>
37256>>>>>>>        Function_Return (sNewHash = sHash)
37257>>>>>>>    End_Function
37258>>>>>>>    
37258>>>>>>>    Function RequiredBufferSizeEx UInteger uiAlgo UInteger uiSaltSize UInteger uiOptTimeCost Returns UBigInt
37260>>>>>>>        Boolean bRequireTimeCost
37260>>>>>>>        UBigInt ullSize
37260>>>>>>>        UChar[] ucaSalt
37261>>>>>>>        String sSalt
37261>>>>>>>        
37261>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
37262>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
37263>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return 0
37266>>>>>>>        
37266>>>>>>>        Case Begin
37266>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
37268>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA256" to ullSize
37269>>>>>>>                Move True to bRequireTimeCost
37270>>>>>>>                Case Break
37271>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
37274>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA512" to ullSize
37275>>>>>>>                Move True to bRequireTimeCost
37276>>>>>>>                Case Break
37277>>>>>>>            Case Else
37277>>>>>>>                Error 8710 "Invalid algorithm selected."
37278>>>>>>>>
37278>>>>>>>                Function_Return 0
37279>>>>>>>        Case End
37279>>>>>>>        
37279>>>>>>>        // calculate base64 in a non-floating-manner
37279>>>>>>>        Move (((ullSize + 3 -1) / 3) * 4) to ullSize
37280>>>>>>>        
37280>>>>>>>        Move (ullSize + SizeOfString(String(uiAlgo))) to ullSize
37281>>>>>>>        Move (ullSize + SizeOfString(sSalt)) to ullSize
37282>>>>>>>        If (bRequireTimeCost) Begin
37284>>>>>>>            Move (ullSize + SizeOfString(String(uiOptTimeCost))) to ullSize
37285>>>>>>>            Move (ullSize + 3 /*$*/) to ullSize
37286>>>>>>>        End
37286>>>>>>>>
37286>>>>>>>        Else Begin
37287>>>>>>>            Move (ullSize + 2 /*$*/) to ullSize
37288>>>>>>>        End
37288>>>>>>>>
37288>>>>>>>        
37288>>>>>>>        Function_Return ullSize
37289>>>>>>>    End_Function
37290>>>>>>>End_Class
