38334>>>    Set Server to oLigaDD
38335>>>
38335>>>    Set peWebViewStyle to wvsDrillDown
38336>>>    Set peViewType to vtZoom
38337>>>    Set pbShowCaption to False
38338>>>    Set Verify_Save_msg to 0 // don't confirm saves
38339>>>    Set pbShowCaption to False    
