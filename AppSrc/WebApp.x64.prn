38514>>>    // This can be used to show and hide buttons based on context.
38514>>>    // This can be called any time the view is active.
38514>>>    Procedure SetActionButtons
38517>>>        tWebNavigateData NavigateData
38517>>>        tWebNavigateData NavigateData
38517>>>        Boolean bHasRecord
38517>>>        Handle hoDD
38517>>>
38517>>>        Get Server to hoDD
38518>>>
38518>>>        Get GetNavigateData to NavigateData
38519>>>        
38519>>>        If (hoDD) Begin
38521>>>            Get HasRecord of hoDD to bHasRecord
38522>>>        End
38522>>>>
38522>>>        Else Begin
38523>>>            Move False to bHasRecord
38524>>>        End
38524>>>>
38524>>>
38524>>>        // let's hide all buttons and then show the ones we want
38524>>>        WebSet pbRender of oEditBtn to False 
38525>>>        WebSet pbRender of oSaveBtn to False
38526>>>        WebSet pbRender of oCancelChangesBtn to False
38527>>>        WebSet pbRender of oDeleteBtn to False
38528>>>
38528>>>        If (NavigateData.bReadOnly) Begin 
38530>>>            WebSet pbRender of oEditBtn to True 
38531>>>        End
38531>>>>
38531>>>        Else Begin
38532>>>            WebSet pbRender of oSaveBtn to True
38533>>>            WebSet pbRender of oCancelChangesBtn to True
38534>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38535>>>        End
38535>>>>
38535>>>    End_Procedure
