37119>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return False
37122>>>>>>>        Get Base64EncodeArr ucaHash to sHash
37123>>>>>>>        If (not(SizeOfString(sHash))) Function_Return False
37126>>>>>>>        
37126>>>>>>>        If (bRequireTimeCost) Begin
37128>>>>>>>            Move (SFormat("%1$%2$%3$%4",            ;                            String(uiAlgo),         ;                            sSalt,                  ;                            String(uiOptTimeCost),  ;                            sHash)) to sHash
37129>>>>>>>        End
37129>>>>>>>>
37129>>>>>>>        Else Begin
37130>>>>>>>            Move (SFormat("%1$%2$%3",               ;                            String(uiAlgo),         ;                            sSalt,                  ;                            sHash)) to sHash
37131>>>>>>>        End
37131>>>>>>>>
37131>>>>>>>        
37131>>>>>>>        Function_Return bOk
37132>>>>>>>    End_Function
