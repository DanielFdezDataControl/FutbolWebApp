38989>>>    // This can be used to show and hide buttons based on context.
38989>>>    // This can be called any time the view is active.
38989>>>    Procedure SetActionButtons
38992>>>        tWebNavigateData NavigateData
38992>>>        tWebNavigateData NavigateData
38992>>>        Boolean bHasRecord
38992>>>        Handle hoDD
38992>>>
38992>>>        Get Server to hoDD
38993>>>        Get GetNavigateData to NavigateData
38994>>>        
38994>>>        If (hoDD) Begin
38996>>>            Get HasRecord of hoDD to bHasRecord
38997>>>        End
38997>>>>
38997>>>        Else Begin
38998>>>            Move False to bHasRecord
38999>>>        End
38999>>>>
38999>>>
38999>>>        // let's hide all buttons and then show the ones we want
38999>>>        WebSet pbRender of oEditBtn to False 
39000>>>        WebSet pbRender of oSaveBtn to False
39001>>>        WebSet pbRender of oCancelChangesBtn to False
39002>>>        WebSet pbRender of oDeleteBtn to False
39003>>>
39003>>>        If (NavigateData.bReadOnly) Begin 
39005>>>            WebSet pbRender of oEditBtn to True 
39006>>>        End
39006>>>>
39006>>>        Else Begin
39007>>>            WebSet pbRender of oSaveBtn to True
39008>>>            WebSet pbRender of oCancelChangesBtn to True
39009>>>            WebSet pbRender of oDeleteBtn to bHasRecord
39010>>>        End
39010>>>>
39010>>>    End_Procedure
39011>>>
