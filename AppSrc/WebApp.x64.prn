37687>>>    Procedure OnLoad
37690>>>        String sPrevStateHash sView
37690>>>        
37690>>>        Forward Send OnLoad
37692>>>        
37692>>>        //  Store the current state so we can go back to that later (only if it points to a different view)
37692>>>        Get StateHash of ghoWebApp to sPrevStateHash
37693>>>        Send ParseViewStateHash sPrevStateHash (&sView)
37694>>>        If (Lowercase(sView) <> Lowercase(psStateViewName(Self))) Begin
37696>>>            WebSet psPrevStateHash to sPrevStateHash
37697>>>        End
37697>>>>
37697>>>        
37697>>>    End_Procedure
