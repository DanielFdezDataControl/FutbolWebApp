40612>>>    Procedure SetActionButtons
40615>>>        tWebNavigateData NavigateData
40615>>>        tWebNavigateData NavigateData
40615>>>        Boolean bHasRecord
40615>>>        Handle hoDD
40615>>>
40615>>>        Get Server to hoDD
40616>>>        Get GetNavigateData to NavigateData
40617>>>        Get HasRecord of hoDD to bHasRecord
40618>>>
40618>>>        // let's hide all buttons and then Show the ones we want
40618>>>        WebSet pbRender of oEditBtn to False
40619>>>        WebSet pbRender of oSaveBtn to False
40620>>>        WebSet pbRender of oCancelChangesBtn to False
40621>>>        WebSet pbRender of oDeleteBtn to False
40622>>>
40622>>>        If (NavigateData.bReadOnly) Begin
40624>>>            WebSet pbRender of oEditBtn to True
40625>>>        End
40625>>>>
40625>>>        Else Begin
40626>>>            WebSet pbRender of oSaveBtn to True
40627>>>            WebSet pbRender of oCancelChangesBtn to True
40628>>>            WebSet pbRender of oDeleteBtn to bHasRecord
40629>>>        End
40629>>>>
40629>>>    End_Procedure
