39191>>>    // This can be used to show and hide buttons based on context.
39191>>>    // This can be called any time the view is active.
39191>>>    Procedure SetActionButtons
39194>>>        tWebNavigateData NavigateData
39194>>>        tWebNavigateData NavigateData
39194>>>        Boolean bHasRecord
39194>>>        Handle hoDD
39194>>>
39194>>>        Get Server to hoDD
39195>>>        Get GetNavigateData to NavigateData
39196>>>        
39196>>>        If (hoDD) Begin
39198>>>            Get HasRecord of hoDD to bHasRecord
39199>>>        End
39199>>>>
39199>>>        Else Begin
39200>>>            Move False to bHasRecord
39201>>>        End
39201>>>>
39201>>>
39201>>>        // let's hide all buttons and then show the ones we want
39201>>>        WebSet pbRender of oEditBtn to False 
39202>>>        WebSet pbRender of oSaveBtn to False
39203>>>        WebSet pbRender of oCancelChangesBtn to False
39204>>>        WebSet pbRender of oDeleteBtn to False
39205>>>
39205>>>        If (NavigateData.bReadOnly) Begin 
39207>>>            WebSet pbRender of oEditBtn to True 
39208>>>        End
39208>>>>
39208>>>        Else Begin
39209>>>            WebSet pbRender of oSaveBtn to True
39210>>>            WebSet pbRender of oCancelChangesBtn to True
39211>>>            WebSet pbRender of oDeleteBtn to bHasRecord
39212>>>        End
39212>>>>
39212>>>    End_Procedure
