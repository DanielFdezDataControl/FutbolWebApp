38644>>>    // Add code to customize your Zoom View based on how it was invoked.
38644>>>    // Use NavigateData to determine the context this view will be used in.
38644>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
38647>>>
38647>>>        // if this view is being used in multiple contexts, you may need a block of code
38647>>>        // like this to handle customizations. This would include hiding rows and buttons
38647>>>        // (WebSet pbRender) and changing the values of various captions.
38647>>>        Case Begin
38647>>>            Case (NavigateData.eNavigateType = nfFromMain)
38649>>>                // If from main, this is a probably a main file Select to Zoom.
38649>>>                // This is the most typical way to navigate to a zoom.
38649>>>                Case Break
38650>>>                
38650>>>            Case (NavigateData.eNavigateType = nfFromParent)
38653>>>                // If from parent, this is a constrained drill down.
38653>>>                // If needed, you could check NavigateData.iTable to determine the constraining parent.
38653>>>                // This would be unusual - normally you drill down from a parent to a list (Select view).
38653>>>                Case Break
38654>>>                
38654>>>            Case (NavigateData.eNavigateType = nfFromChild)
38657>>>                // If from child, this is a probably a parent Zoom from a Zoom. 
38657>>>                // This is unusual, but it might be used for adding a new child record.
38657>>>                Case Break
38658>>>                
38658>>>            Case Else // must be nfUndefined
38658>>>                // This may be the start of a query or this may be used for some kind of custom operation.
38658>>>                // You may want to check NavigateData.NamedValues.
38658>>>                  
38658>>>        Case End
38658>>>
38658>>>        // Action buttons can be changed dynamically during a Zoom's display lifetime.
38658>>>        // It's best to set these buttons in their own procedure so you can change later.
38658>>>        Send SetActionButtons
38659>>>        
38659>>>        If (HasRecord(Server(Self))) Begin 
38661>>>            Send SetHeaderCaption    ("Liga:"*liga.Nombre)
38662>>>            Send SetBreadcrumbCaption liga.Nombre
38663>>>        End
38663>>>>
38663>>>        Else Begin 
38664>>>            Send SetHeaderCaption     "Nueva Liga"
38665>>>            Send SetBreadcrumbCaption "Nueva"
38666>>>        End
38666>>>>
38666>>>        //------                 
38666>>>        Send Rebuild_Constraints of oJugadorDD
38667>>>        Send RefreshListFromDD of oJugadoresEquipo_List
38668>>>        
38668>>>        Send Rebuild_Constraints of oEntrenadorDD
38669>>>        Send RefreshListFromDD of oEntrenadorEquipo_List
38670>>>        //------
38670>>>    End_Procedure
38671>>>    
38671>>>    
38671>>>
38671>>>End_Object
