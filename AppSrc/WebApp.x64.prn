38546>>>    // Add code to customize your Zoom View based on how it was invoked.
38546>>>    // Use NavigateData to determine the context this view will be used in.
38546>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
38549>>>
38549>>>        // if this view is being used in multiple contexts, you may need a block of code
38549>>>        // like this to handle customizations. This would include hiding rows and buttons
38549>>>        // (WebSet pbRender) and changing the values of various captions.
38549>>>        Case Begin
38549>>>            Case (NavigateData.eNavigateType = nfFromMain)
38551>>>                // If from main, this is a probably a main file Select to Zoom.
38551>>>                // This is the most typical way to navigate to a zoom.
38551>>>                Case Break
38552>>>                
38552>>>            Case (NavigateData.eNavigateType = nfFromParent)
38555>>>                // If from parent, this is a constrained drill down.
38555>>>                // If needed, you could check NavigateData.iTable to determine the constraining parent.
38555>>>                // This would be unusual - normally you drill down from a parent to a list (Select view).
38555>>>                Case Break
38556>>>                
38556>>>            Case (NavigateData.eNavigateType = nfFromChild)
38559>>>                // If from child, this is a probably a parent Zoom from a Zoom. 
38559>>>                // This is unusual, but it might be used for adding a new child record.
38559>>>                Case Break
38560>>>                
38560>>>            Case Else // must be nfUndefined
38560>>>                // This may be the start of a query or this may be used for some kind of custom operation.
38560>>>                // You may want to check NavigateData.NamedValues.
38560>>>                  
38560>>>        Case End
38560>>>
38560>>>        // Action buttons can be changed dynamically during a Zoom's display lifetime.
38560>>>        // It's best to set these buttons in their own procedure so you can change later.
38560>>>        Send SetActionButtons
38561>>>        
38561>>>        If (HasRecord(Server(Self))) Begin 
38563>>>            Send SetHeaderCaption    ("Liga:"*liga.Nombre)
38564>>>            Send SetBreadcrumbCaption liga.Nombre
38565>>>        End
38565>>>>
38565>>>        Else Begin 
38566>>>            Send SetHeaderCaption     "Nueva Liga"
38567>>>            Send SetBreadcrumbCaption "Nueva"
38568>>>        End
38568>>>>
38568>>>        //------                 
38568>>>        Send Rebuild_Constraints of oJugadorDD
38569>>>        Send RefreshListFromDD of oJugadoresEquipo_List
38570>>>        
38570>>>        Send Rebuild_Constraints of oEntrenadorDD
38571>>>        Send RefreshListFromDD of oEntrenadorEquipo_List
38572>>>        //------
38572>>>    End_Procedure
38573>>>    
38573>>>    
38573>>>
38573>>>End_Object
