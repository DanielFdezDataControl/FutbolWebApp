42441>>>    Procedure SetActionButtons
42444>>>        tWebNavigateData NavigateData
42444>>>        tWebNavigateData NavigateData
42444>>>        Boolean bHasRecord
42444>>>        Handle hoDD
42444>>>
42444>>>        Get Server to hoDD
42445>>>        Get GetNavigateData to NavigateData
42446>>>        Get HasRecord of hoDD to bHasRecord
42447>>>
42447>>>        // let's hide all buttons and then Show the ones we want
42447>>>        WebSet pbRender of oEditBtn to False
42448>>>        WebSet pbRender of oSaveBtn to False
42449>>>        WebSet pbRender of oCancelChangesBtn to False
42450>>>        WebSet pbRender of oDeleteBtn to False
42451>>>
42451>>>        If (NavigateData.bReadOnly) Begin
42453>>>            WebSet pbRender of oEditBtn to True
42454>>>        End
42454>>>>
42454>>>        Else Begin
42455>>>            WebSet pbRender of oSaveBtn to True
42456>>>            WebSet pbRender of oCancelChangesBtn to True
42457>>>            WebSet pbRender of oDeleteBtn to bHasRecord
42458>>>        End
42458>>>>
42458>>>    End_Procedure
42459>>>
42459>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
42462>>>        // Close after save
42462>>>        Send NavigateClose Self
42463>>>    End_Procedure
42464>>>
42464>>>    // this will close the view after a delete
42464>>>    Procedure OnViewDeleted Handle hoDDO
42467>>>        Send NavigateClose Self
42468>>>    End_Procedure
42469>>>
42469>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
42472>>>        Case Begin
42472>>>            Case (NavigateData.eNavigateType = nfFromMain)
42474>>>                // If from main, this is a propbably a main file Select to Zoom.
42474>>>                Case Break
42475>>>
42475>>>            Case (NavigateData.eNavigateType = nfFromParent)
42478>>>                // If from parent, this is a constrained drill down.
42478>>>                Case Break
42479>>>
42479>>>            Case (NavigateData.eNavigateType = nfFromChild)
42482>>>                // If from child, this is a probably a parent Zoom from a Zoom.
42482>>>                Case Break
42483>>>
42483>>>            Case Else // must be nfUndefined
42483>>>
42483>>>        Case End
42483>>>
42483>>>        If (HasRecord(Server(Self))) Begin 
42485>>>            Send SetHeaderCaption    ("TablaHijo:"*tablahijo.Name)
42486>>>            Send SetBreadcrumbCaption (tablahijo.Name)
42487>>>        End
42487>>>>
42487>>>        Else Begin 
42488>>>            Send SetHeaderCaption     "Nuevo TablaHijo"
42489>>>            Send SetBreadcrumbCaption "Nuevo"
42490>>>        End
42490>>>>
42490>>>
42490>>>
42490>>>        Send SetActionButtons
42491>>>
42491>>>    End_Procedure
42492>>>
42492>>>End_Object 
