37704>>>    Procedure DoLogin
37707>>>        String sLoginName sPassword sPrevStateHash
37707>>>        Boolean bResult
37707>>>        
37707>>>        WebGet psValue of oLoginName to sLoginName
37708>>>        WebGet psValue of oPassword to sPassword
37709>>>        
37709>>>        Get UserLogin of ghoWebSessionManager sLoginName sPassword to bResult
37710>>>        
37710>>>        If (bResult) Begin
37712>>>            Send Hide of oLogin
37713>>>            Send ShowHeader of ghoWebApp
37714>>>            WebSet psCSSClass of ghoWebApp to ""
37715>>>            
37715>>>            WebGet psPrevStateHash to sPrevStateHash
37716>>>            Send NavigateToStateHash of ghoWebApp sPrevStateHash True
37717>>>            
37717>>>            // clear the login values. we don't want to return the login id & password as synchronized properties....
37717>>>            WebSet psValue of oLoginName to ""
37718>>>            WebSet psValue of oPassword  to ""
37719>>>            WebSet pbVisible of oWarning to False
37720>>>        End
37720>>>>
37720>>>        Else Begin
37721>>>            WebSet pbVisible of oWarning to True
37722>>>        End
37722>>>>
37722>>>    End_Procedure
37723>>>    
37723>>>    Procedure OnSubmit
37726>>>        Send DoLogin
37727>>>    End_Procedure
