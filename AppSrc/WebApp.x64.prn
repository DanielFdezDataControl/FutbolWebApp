36955>>>>>>>    //
36955>>>>>>>    //  Converts the given time to an string that can be saved in the database.
36955>>>>>>>    //
36955>>>>>>>    //  Params:
36955>>>>>>>    //      dtTime  Time to convert
36955>>>>>>>    //  Returns:
36955>>>>>>>    //      String with "HH:MM:SS" format
36955>>>>>>>    //
36955>>>>>>>    Function TimeToString DateTime dtTime Returns String
36957>>>>>>>        String sHours sMinutes sSeconds
36957>>>>>>>        
36957>>>>>>>        //  Extract parts
36957>>>>>>>        Move (String(DateGetHour(dtTime))) to sHours
36958>>>>>>>        Move (String(DateGetMinute(dtTime))) to sMinutes
36959>>>>>>>        Move (String(DateGetSecond(dtTime))) to sSeconds
36960>>>>>>>        
36960>>>>>>>        //  Fill out with 0
36960>>>>>>>        If (Length(sHours) = 1) ;            Move ("0" + sHours) to sHours
36963>>>>>>>        If (Length(sMinutes) = 1) ;            Move ("0" + sMinutes) to sMinutes
36966>>>>>>>        If (Length(sSeconds) = 1) ;            Move ("0" + sSeconds) to sSeconds
36969>>>>>>>        
36969>>>>>>>        Function_Return (sHours + ":" + sMinutes + ":" + sSeconds)
36970>>>>>>>    End_Function
36971>>>>>>>    
36971>>>>>>>    //
36971>>>>>>>    //  Sets the time of the datetime variable to the time in the string.
36971>>>>>>>    //
36971>>>>>>>    //  Params:
36971>>>>>>>    //      dtTime  Datetime variable to add time to
36971>>>>>>>    //      sTimeString String with time in the format "HH:MM:SS"
36971>>>>>>>    //  Returns:
36971>>>>>>>    //      dtDateTime with the loaded time
36971>>>>>>>    //
36971>>>>>>>    Function StringToTime DateTime dtTime String sTimeString Returns DateTime
36973>>>>>>>        String sHours sMinutes sSeconds
36973>>>>>>>        
36973>>>>>>>        //  Extract parts
36973>>>>>>>        Move (Mid(sTimeString, 2, 1)) to sHours
36974>>>>>>>        Move (Mid(sTimeString, 2, 4)) to sMinutes
36975>>>>>>>        Move (Mid(sTimeString, 2, 7)) to sSeconds
36976>>>>>>>        
36976>>>>>>>        //  Set to DateTime
36976>>>>>>>        Move (DateSetHour(dtTime, (Integer(sHours)))) to dtTime
36977>>>>>>>        Move (DateSetMinute(dtTime, (Integer(sMinutes)))) to dtTime
36978>>>>>>>        Move (DateSetSecond(dtTime, (Integer(sSeconds)))) to dtTime
36979>>>>>>>        
36979>>>>>>>        Function_Return dtTime
36980>>>>>>>    End_Function
