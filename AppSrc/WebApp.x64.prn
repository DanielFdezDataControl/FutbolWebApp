37004>>>>>>>        Move dtCurrentDateTime to WebAppSession.LastAccessDate
37005>>>>>>>    End_Procedure
37006>>>>>>>    
37006>>>>>>>    //
37006>>>>>>>    //  Converts the given time to an string that can be saved in the database.
37006>>>>>>>    //
37006>>>>>>>    //  Params:
37006>>>>>>>    //      dtTime  Time to convert
37006>>>>>>>    //  Returns:
37006>>>>>>>    //      String with "HH:MM:SS" format
37006>>>>>>>    //
37006>>>>>>>    Function TimeToString DateTime dtTime Returns String
37008>>>>>>>        String sHours sMinutes sSeconds
37008>>>>>>>        
37008>>>>>>>        //  Extract parts
37008>>>>>>>        Move (String(DateGetHour(dtTime))) to sHours
37009>>>>>>>        Move (String(DateGetMinute(dtTime))) to sMinutes
37010>>>>>>>        Move (String(DateGetSecond(dtTime))) to sSeconds
37011>>>>>>>        
37011>>>>>>>        //  Fill out with 0
37011>>>>>>>        If (Length(sHours) = 1) ;            Move ("0" + sHours) to sHours
37014>>>>>>>        If (Length(sMinutes) = 1) ;            Move ("0" + sMinutes) to sMinutes
37017>>>>>>>        If (Length(sSeconds) = 1) ;            Move ("0" + sSeconds) to sSeconds
37020>>>>>>>        
37020>>>>>>>        Function_Return (sHours + ":" + sMinutes + ":" + sSeconds)
37021>>>>>>>    End_Function
37022>>>>>>>    
37022>>>>>>>    //
37022>>>>>>>    //  Sets the time of the datetime variable to the time in the string.
37022>>>>>>>    //
37022>>>>>>>    //  Params:
37022>>>>>>>    //      dtTime  Datetime variable to add time to
37022>>>>>>>    //      sTimeString String with time in the format "HH:MM:SS"
37022>>>>>>>    //  Returns:
37022>>>>>>>    //      dtDateTime with the loaded time
37022>>>>>>>    //
37022>>>>>>>    Function StringToTime DateTime dtTime String sTimeString Returns DateTime
37024>>>>>>>        String sHours sMinutes sSeconds
37024>>>>>>>        
37024>>>>>>>        //  Extract parts
37024>>>>>>>        Move (Mid(sTimeString, 2, 1)) to sHours
37025>>>>>>>        Move (Mid(sTimeString, 2, 4)) to sMinutes
37026>>>>>>>        Move (Mid(sTimeString, 2, 7)) to sSeconds
37027>>>>>>>        
37027>>>>>>>        //  Set to DateTime
37027>>>>>>>        Move (DateSetHour(dtTime, (Integer(sHours)))) to dtTime
37028>>>>>>>        Move (DateSetMinute(dtTime, (Integer(sMinutes)))) to dtTime
37029>>>>>>>        Move (DateSetSecond(dtTime, (Integer(sSeconds)))) to dtTime
37030>>>>>>>        
37030>>>>>>>        Function_Return dtTime
37031>>>>>>>    End_Function
37032>>>>>>>End_Class
