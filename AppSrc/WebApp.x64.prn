37080>>>>>>>            Function_Return 0
37081>>>>>>>        End
37081>>>>>>>>
37081>>>>>>>        
37081>>>>>>>        Get CNG_PBKDF2_HMAC_BufferSizeEx hoProv to uiHashLen
37082>>>>>>>        
37082>>>>>>>        Move (CNG_BCryptCloseAlgorithmProvider(hoProv, 0)) to iErr
37083>>>>>>>        
37083>>>>>>>        Function_Return uiHashLen
37084>>>>>>>    End_Function
37085>>>>>>>    
37085>>>>>>>    Function CNG_PBKDF2_HMAC    WString wsAlgo ;                                UChar[] ucaData ;                                UChar[] ucaSalt ;                                UInteger uiTimeCost ;                                UChar[] ByRef ucaHashOut ;                                Boolean bOptThrow ;                                Returns Boolean
37087>>>>>>>        Integer iErr iHashLen
37087>>>>>>>        
37087>>>>>>>        // Handle Optionals
37087>>>>>>>        // First the optional throwing of errors.
37087>>>>>>>        Boolean bThrow
37087>>>>>>>        Move True to bThrow
37088>>>>>>>        If (num_arguments > 4) Move bOptThrow to bThrow
37091>>>>>>>        
37091>>>>>>>        // Open the algorithm.
37091>>>>>>>        Handle hoProv
37091>>>>>>>        Move (CNG_BCryptOpenAlgorithmProvider(AddressOf(hoProv), AddressOf(wsAlgo), 0, |CI$00000008 /*BCRYPT_ALG_HANDLE_HMAC_FLAG*/)) to iErr
37092>>>>>>>        If (iErr) Begin
37094>>>>>>>            If (bThrow) Error 8710 "Failed to open up the algo provider."
37097>>>>>>>            Function_Return False
37098>>>>>>>        End
37098>>>>>>>>
37098>>>>>>>        
37098>>>>>>>        Get CNG_PBKDF2_HMAC_BufferSizeEx hoProv to iHashLen
37099>>>>>>>        If (not(iHashLen)) Begin
37101>>>>>>>            If (bThrow) Error 8710 "Failed to get expected length of hash."
37104>>>>>>>            Function_Return False
37105>>>>>>>        End
37105>>>>>>>>
37105>>>>>>>        
37105>>>>>>>        // Resize buffers to the expected output.
37105>>>>>>>        Move (ResizeArray(ucaHashOut, iHashLen)) to ucaHashOut
37106>>>>>>>        
37106>>>>>>>        Move (CNG_BCryptDeriveKeyPBKDF2(hoProv, AddressOf(ucaData), SizeOfArray(ucaData), AddressOf(ucaSalt), SizeOfArray(ucaSalt), uiTimeCost, AddressOf(ucaHashOut), SizeOfArray(ucaHashOut), 0)) to iErr
37107>>>>>>>        If (iErr) Begin
37109>>>>>>>            Move (CNG_BCryptCloseAlgorithmProvider(hoProv, 0)) to iErr
37110>>>>>>>            If (bThrow) Error 8710 "Failed to create hash."
37113>>>>>>>            Function_Return False
37114>>>>>>>        End
37114>>>>>>>>
37114>>>>>>>        
37114>>>>>>>        Move (CNG_BCryptCloseAlgorithmProvider(hoProv, 0)) to iErr
37115>>>>>>>        If (iErr) Begin
37117>>>>>>>            If (bThrow) Error 8710 "Failed to close algo provider."
37120>>>>>>>            Function_Return False
37121>>>>>>>        End
37121>>>>>>>>
37121>>>>>>>        
37121>>>>>>>        Function_Return True
37122>>>>>>>    End_Function
37123>>>>>>>End_Class
