38748>>>    // This can be used to show and hide buttons based on context.
38748>>>    // This can be called any time the view is active.
38748>>>    Procedure SetActionButtons
38751>>>        tWebNavigateData NavigateData
38751>>>        tWebNavigateData NavigateData
38751>>>        Boolean bHasRecord
38751>>>        Handle hoDD
38751>>>
38751>>>        Get Server to hoDD
38752>>>
38752>>>        Get GetNavigateData to NavigateData
38753>>>        
38753>>>        If (hoDD) Begin
38755>>>            Get HasRecord of hoDD to bHasRecord
38756>>>        End
38756>>>>
38756>>>        Else Begin
38757>>>            Move False to bHasRecord
38758>>>        End
38758>>>>
38758>>>
38758>>>        // let's hide all buttons and then show the ones we want
38758>>>        WebSet pbRender of oEditBtn to False 
38759>>>        WebSet pbRender of oSaveBtn to False
38760>>>        WebSet pbRender of oCancelChangesBtn to False
38761>>>        WebSet pbRender of oDeleteBtn to False
38762>>>
38762>>>        If (NavigateData.bReadOnly) Begin 
38764>>>            WebSet pbRender of oEditBtn to True 
38765>>>        End
38765>>>>
38765>>>        Else Begin
38766>>>            WebSet pbRender of oSaveBtn to True
38767>>>            WebSet pbRender of oCancelChangesBtn to True
38768>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38769>>>        End
38769>>>>
38769>>>    End_Procedure
