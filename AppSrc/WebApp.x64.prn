38408>>>            Move iLigaID to equipo.LigaID
38409>>>            Send Request_Read to oEquipoDD FIRST_RECORD equipo.File_Number 1
38410>>>            While (Found)
38414>>>                Move equipo.ID to saEquiposDeLigaID[-1]                   
38415>>>                Send Request_Read to oEquipoDD NEXT_RECORD equipo.File_Number 1
38416>>>            Loop
38417>>>>
38417>>>            If (SizeOfArray(saEquiposDeLigaID) > 0) Begin
38419>>>                Move ("(jugador.equipoID = " + String(saEquiposDeLigaID[0]) + ")") to sConsulta                
38420>>>                For iCont from 1 to (SizeOfArray(saEquiposDeLigaID) - 1)
38426>>>>
38426>>>                    Move (sConsulta + " OR (jugador.equipoID = " + String(saEquiposDeLigaID[iCont]) + ")") to sConsulta
38427>>>                Loop                
38428>>>>
38428>>>            End            
38428>>>>
38428>>>            Set psSQLFilter to ("("+ sConsulta + ")")
38429>>>        End_Procedure
