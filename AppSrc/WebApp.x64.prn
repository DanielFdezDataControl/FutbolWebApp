37104>>>>>>>Class cPasswordHasher_Mixin is a Mixin
37105>>>>>>>    
37105>>>>>>>    Import_Class_Protocol cPasswordHasher_CNG_PBKDF2_HMAC_Mixin
37106>>>>>>>    
37106>>>>>>>    Enum_List // Algorithmes available for password hashing
37106>>>>>>>        Define C_PWH_PBKDF2_HMAC_SHA_256        for 0 // Requires TimeCost
37106>>>>>>>        Define C_PWH_PBKDF2_HMAC_SHA_512              // Requires TimeCost
37106>>>>>>>    End_Enum_List
37106>>>>>>>    
37106>>>>>>>    Function RandomBuffer UInteger uiSize Returns UChar[]
37108>>>>>>>        UChar[] ucaBuffer
37109>>>>>>>        Move (ResizeArray(ucaBuffer, uiSize)) to ucaBuffer
37110>>>>>>>        If (CNG_BCryptGenRandom(0, AddressOf(ucaBuffer), uiSize, |CI$00000002 /*BCRYPT_USE_SYSTEM_PREFERRED_RNG*/)) Begin
37112>>>>>>>            Error 8710 "Failed to create random buffer."
37113>>>>>>>>
37113>>>>>>>        End
37113>>>>>>>>
37113>>>>>>>        Function_Return ucaBuffer
37114>>>>>>>    End_Function
37115>>>>>>>    
37115>>>>>>>    Function Base64EncodeArr UChar[] ucaBuffer Returns String
37117>>>>>>>        Integer iErr
37117>>>>>>>        Pointer pBase64
37117>>>>>>>        String sBase64
37117>>>>>>>        Move (Base64Encode(AddressOf(ucaBuffer), SizeOfArray(ucaBuffer))) to pBase64
37118>>>>>>>        If (not(pBase64)) Begin
37120>>>>>>>            Function_Return sBase64
37121>>>>>>>        End
37121>>>>>>>>
37121>>>>>>>        Move (PointerToString(pBase64)) to sBase64
37122>>>>>>>        Move (Free(pBase64)) to iErr
37123>>>>>>>        Function_Return sBase64
37124>>>>>>>    End_Function
37125>>>>>>>    
37125>>>>>>>    Function Base64DecodeArr String sBase64 Returns UChar[]
37127>>>>>>>        Integer iLen
37127>>>>>>>        Pointer pBase64
37127>>>>>>>        UChar[] ucaBuffer
37128>>>>>>>        Move (Base64Decode(AddressOf(sBase64), &iLen)) to pBase64
37129>>>>>>>        If (not(pBase64)) Begin
37131>>>>>>>            Function_Return ucaBuffer
37132>>>>>>>        End
37132>>>>>>>>
37132>>>>>>>        
37132>>>>>>>        Move (ResizeArray(ucaBuffer, iLen)) to ucaBuffer
37133>>>>>>>        Move (MemCopy(AddressOf(ucaBuffer), pBase64, iLen)) to iLen
37134>>>>>>>        Move (Free(pBase64)) to iLen
37135>>>>>>>        Function_Return ucaBuffer
37136>>>>>>>    End_Function
37137>>>>>>>    
37137>>>>>>>    Function CreatePasswordHashExWithSalt UInteger uiAlgo UChar[] ucaSalt String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
37139>>>>>>>        Boolean bOk bRequireTimeCost
37139>>>>>>>        UChar[] ucaHash
37140>>>>>>>        
37140>>>>>>>        Case Begin
37140>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
37142>>>>>>>                Get CNG_PBKDF2_HMAC "SHA256" (StringToUCharArray(sPassword)) ucaSalt uiOptTimeCost (&ucaHash) False to bOk
37143>>>>>>>                If (not(bOk)) Function_Return False
37146>>>>>>>                
37146>>>>>>>                Move True to bRequireTimeCost
37147>>>>>>>                Case Break
37148>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
37151>>>>>>>                Get CNG_PBKDF2_HMAC "SHA512" (StringToUCharArray(sPassword)) ucaSalt uiOptTimeCost (&ucaHash) False to bOk
37152>>>>>>>                If (not(bOk)) Function_Return False
37155>>>>>>>                
37155>>>>>>>                Move True to bRequireTimeCost
37156>>>>>>>                Case Break
37157>>>>>>>            Case Else
37157>>>>>>>                Error 8710 "Invalid algorithm selected."
37158>>>>>>>>
37158>>>>>>>                Function_Return False
37159>>>>>>>        Case End
37159>>>>>>>        
37159>>>>>>>        String sSalt
37159>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
37160>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return False
37163>>>>>>>        Get Base64EncodeArr ucaHash to sHash
37164>>>>>>>        If (not(SizeOfString(sHash))) Function_Return False
37167>>>>>>>        
37167>>>>>>>        If (bRequireTimeCost) Begin
37169>>>>>>>            Move (SFormat("%1$%2$%3$%4",            ;                            String(uiAlgo),         ;                            sSalt,                  ;                            String(uiOptTimeCost),  ;                            sHash)) to sHash
37170>>>>>>>        End
37170>>>>>>>>
37170>>>>>>>        Else Begin
37171>>>>>>>            Move (SFormat("%1$%2$%3",               ;                            String(uiAlgo),         ;                            sSalt,                  ;                            sHash)) to sHash
37172>>>>>>>        End
37172>>>>>>>>
37172>>>>>>>        
37172>>>>>>>        Function_Return bOk
37173>>>>>>>    End_Function
37174>>>>>>>    
37174>>>>>>>    Function CreatePasswordHashEx UInteger uiAlgo UInteger uiSaltSize String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
37176>>>>>>>        UChar[] ucaSalt
37177>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
37178>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
37181>>>>>>>        
37181>>>>>>>        If (num_arguments > 4) Begin
37183>>>>>>>            Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash, uiOptTimeCost))
37184>>>>>>>        End
37184>>>>>>>>
37184>>>>>>>        Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash))
37185>>>>>>>    End_Function
37186>>>>>>>    
37186>>>>>>>    Function VerifyPasswordHash String sPassword String sHash Returns Boolean
37188>>>>>>>        Boolean bRequiresTimeCost
37188>>>>>>>        UInteger uiAlgo uiTimeCost
37188>>>>>>>        Integer iBegin iEnd
37188>>>>>>>        String sSalt
37188>>>>>>>        
37188>>>>>>>        Move 1 to iBegin
37189>>>>>>>        
37189>>>>>>>        // Parse Algo
37189>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
37190>>>>>>>        If (not(iEnd)) Function_Return False
37193>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiAlgo
37194>>>>>>>        
37194>>>>>>>        // Parse Salt
37194>>>>>>>        Move (iEnd + 1) to iBegin
37195>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
37196>>>>>>>        If (not(iEnd)) Function_Return False
37199>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to sSalt
37200>>>>>>>        
37200>>>>>>>        Case Begin
37200>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
37202>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
37205>>>>>>>                Move True to bRequiresTimeCost
37206>>>>>>>                Case Break
37207>>>>>>>            Case Else
37207>>>>>>>                Error 8710 "Invalid algorithm selected."
37208>>>>>>>>
37208>>>>>>>                Function_Return False
37209>>>>>>>        Case End
37209>>>>>>>        
37209>>>>>>>        // Parse optional timecost
37209>>>>>>>        If (bRequiresTimeCost) Begin
37211>>>>>>>            Move (iEnd + 1) to iBegin
37212>>>>>>>            Move (Pos("$", sHash, iBegin)) to iEnd
37213>>>>>>>            If (not(iEnd)) Function_Return False
37216>>>>>>>            Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiTimeCost
37217>>>>>>>        End
37217>>>>>>>>
37217>>>>>>>        
37217>>>>>>>        // Parse rest hash
37217>>>>>>>        Move (iEnd + 1) to iBegin
37218>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
37219>>>>>>>        If (iEnd) Function_Return False // inverse check if there are any other errors.
37222>>>>>>>        
37222>>>>>>>        // Base64Decode
37222>>>>>>>        UChar[] ucaSalt
37223>>>>>>>        Get Base64DecodeArr sSalt to ucaSalt
37224>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
37227>>>>>>>        
37227>>>>>>>        // Create new hash
37227>>>>>>>        String sNewHash
37227>>>>>>>        If (bRequiresTimeCost) Begin
37229>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash, uiTimeCost))) Begin
37231>>>>>>>                Function_Return False 
37232>>>>>>>            End
37232>>>>>>>>
37232>>>>>>>        End
37232>>>>>>>>
37232>>>>>>>        Else Begin
37233>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash))) Begin
37235>>>>>>>                Function_Return False 
37236>>>>>>>            End
37236>>>>>>>>
37236>>>>>>>        End
37236>>>>>>>>
37236>>>>>>>        Function_Return (sNewHash = sHash)
37237>>>>>>>    End_Function
37238>>>>>>>    
37238>>>>>>>    Function RequiredBufferSizeEx UInteger uiAlgo UInteger uiSaltSize UInteger uiOptTimeCost Returns UBigInt
37240>>>>>>>        Boolean bRequireTimeCost
37240>>>>>>>        UBigInt ullSize
37240>>>>>>>        UChar[] ucaSalt
37241>>>>>>>        String sSalt
37241>>>>>>>        
37241>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
37242>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
37243>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return 0
37246>>>>>>>        
37246>>>>>>>        Case Begin
37246>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
37248>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA256" to ullSize
37249>>>>>>>                Move True to bRequireTimeCost
37250>>>>>>>                Case Break
37251>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
37254>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA512" to ullSize
37255>>>>>>>                Move True to bRequireTimeCost
37256>>>>>>>                Case Break
37257>>>>>>>            Case Else
37257>>>>>>>                Error 8710 "Invalid algorithm selected."
37258>>>>>>>>
37258>>>>>>>                Function_Return 0
37259>>>>>>>        Case End
37259>>>>>>>        
37259>>>>>>>        // calculate base64 in a non-floating-manner
37259>>>>>>>        Move (((ullSize + 3 -1) / 3) * 4) to ullSize
37260>>>>>>>        
37260>>>>>>>        Move (ullSize + SizeOfString(String(uiAlgo))) to ullSize
37261>>>>>>>        Move (ullSize + SizeOfString(sSalt)) to ullSize
37262>>>>>>>        If (bRequireTimeCost) Begin
37264>>>>>>>            Move (ullSize + SizeOfString(String(uiOptTimeCost))) to ullSize
37265>>>>>>>            Move (ullSize + 3 /*$*/) to ullSize
37266>>>>>>>        End
37266>>>>>>>>
37266>>>>>>>        Else Begin
37267>>>>>>>            Move (ullSize + 2 /*$*/) to ullSize
37268>>>>>>>        End
37268>>>>>>>>
37268>>>>>>>        
37268>>>>>>>        Function_Return ullSize
37269>>>>>>>    End_Function
37270>>>>>>>End_Class
37271>>>>>>>
37271>>>>>>>Class cPasswordHasher is a cObject
37272>>>>>>>    
37272>>>>>>>    Import_Class_Protocol cPasswordHasher_Mixin
37273>>>>>>>    
37273>>>>>>>    Procedure Construct_Object
37275>>>>>>>        Forward Send Construct_Object
37277>>>>>>>        
37277>>>>>>>        Property UInteger   peAlgorithm         C_PWH_PBKDF2_HMAC_SHA_512 
37278>>>>>>>        Property UInteger   puiSaltSize         16
37279>>>>>>>        
37279>>>>>>>        Property UInteger   puiOptTimeCost      420000
37280>>>>>>>    End_Procedure
37281>>>>>>>    
37281>>>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
37283>>>>>>>        Boolean bOk
37283>>>>>>>        UInteger uiAlgo
37283>>>>>>>        Get peAlgorithm to uiAlgo
37284>>>>>>>        
37284>>>>>>>        Case Begin
37284>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
37286>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
37289>>>>>>>                Get CreatePasswordHashEx uiAlgo (puiSaltSize(Self)) sPassword (&sHash) (puiOptTimeCost(Self)) to bOk
37290>>>>>>>                Case Break
37291>>>>>>>            Case Else
37291>>>>>>>                Error 8710 "Invalid algorithm selected."
37292>>>>>>>>
37292>>>>>>>                Function_Return False
37293>>>>>>>        Case End
37293>>>>>>>        
37293>>>>>>>        Function_Return bOk
37294>>>>>>>    End_Function
37295>>>>>>>    
37295>>>>>>>    Function RequiredBufferSize Returns UBigInt
37297>>>>>>>        UBigInt ullSize
37297>>>>>>>        UInteger uiAlgo
37297>>>>>>>        Get peAlgorithm to uiAlgo
37298>>>>>>>        
37298>>>>>>>        Case Begin
37298>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
37300>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
37303>>>>>>>                Get RequiredBufferSizeEx uiAlgo (puiSaltSize(Self)) (puiOptTimeCost(Self)) to ullSize
37304>>>>>>>                Case Break
37305>>>>>>>            Case Else
37305>>>>>>>                Error 8710 "Invalid algorithm selected."
37306>>>>>>>>
37306>>>>>>>                Function_Return 0
37307>>>>>>>        Case End
37307>>>>>>>        
37307>>>>>>>        Function_Return ullSize
37308>>>>>>>    End_Function
37309>>>>>>>
37309>>>>>>>End_Class
37310>>>>>
37310>>>>>Class cWebSessionManagerStandard is a cWebSessionManager
37311>>>>>    
37311>>>>>    Procedure Construct_Object
37313>>>>>        Handle hoObj
37313>>>>>        
37313>>>>>        Forward Send Construct_Object
37315>>>>>        
37315>>>>>        Set pbSessionCookieHttpOnly to True
37316>>>>>        
37316>>>>>        Property Handle phoUserDD 0      // Handle to the WebAppUser DDO
37317>>>>>        Property Handle phoSessionDD 0   // Handle to the WebAppSession DDO  
37318>>>>>        Property Handle phoCrypto 0      // Handle to the PasswordHasher
37319>>>>>        
37319>>>>>        Get CreateNamed (RefClass(cWebAppUserDataDictionary)) 'oUserDD' to hoObj
37320>>>>>        Set phoUserDD to hoObj
37321>>>>>        
37321>>>>>        Get CreateNamed (RefClass(cWebAppSessionDataDictionary)) 'oSessionDD' to hoObj
37322>>>>>        Set DDO_Server of hoObj to (phoUserDD(Self))
37323>>>>>        Set phoSessionDD to hoObj
37324>>>>>        
37324>>>>>        Property Handle phoCrypto 0   // Handle to the Cryptographer
37325>>>>>        Get CreateNamed (RefClass(cPasswordHasher)) 'oCrypto' to hoObj
37326>>>>>        Set phoCrypto to hoObj
37327>>>>>        
37327>>>>>        Property Boolean pbPasswordHashing True
37328>>>>>        
37328>>>>>        Property Boolean pbCreatingNewSession False
37329>>>>>        Property String psLoginName
37330>>>>>        Property String psUserName ""
37331>>>>>        Property Integer piUserRights 0
37332>>>>>    End_Procedure
37333>>>>>    
37333>>>>>    Procedure End_Construct_Object
37335>>>>>        Forward Send End_Construct_Object
37337>>>>>        
37337>>>>>        Handle hoCrypto
37337>>>>>        Integer iFieldLen
37337>>>>>        If (pbPasswordHashing(Self)) Begin
37339>>>>>            Get phoCrypto to hoCrypto
37340>>>>>            Get_Attribute DF_FIELD_LENGTH of (RefTable(WebAppUser)) (RefTable(WebAppUser.Password)) to iFieldLen
37343>>>>>            If (iFieldLen < (RequiredBufferSize(hoCrypto) + 3)) Begin
37345>>>>>                Error DFERR_PROGRAM "The password field of WebAppUser is not large enough (128)"
37346>>>>>>
37346>>>>>            End
37346>>>>>>
37346>>>>>        End
37346>>>>>>
37346>>>>>    End_Procedure
37347>>>>>    
37347>>>>>    Function CreateSession String sRemoteAddress Returns String
37349>>>>>        String sSessionKey
37349>>>>>        Integer iErr
37349>>>>>        Boolean bLogWebSession
37349>>>>>        Handle hoSessionDD       
37349>>>>>        Get phoSessionDD to hoSessionDD
37350>>>>>        
37350>>>>>        //  Get session key
37350>>>>>        Forward Get CreateSession sRemoteAddress to sSessionKey
37352>>>>>        
37352>>>>>        Get pbLogWebSession to bLogWebSession
37353>>>>>        If not bLogWebSession Begin
37355>>>>>            Function_Return sSessionKey        
37356>>>>>        End
37356>>>>>>
37356>>>>>
37356>>>>>        //  Store session
37356>>>>>        Send Clear of hoSessionDD
37357>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.SessionKey to sSessionKey
37358>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.RemoteAddress to sRemoteAddress
37359>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.Active to "Y"
37360>>>>>        Get Request_Validate of hoSessionDD to iErr
37361>>>>>        If (iErr) Begin
37363>>>>>            // this should not happen. If it does its a programming error
37363>>>>>            Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37364>>>>>>
37364>>>>>            Function_Return ""
37365>>>>>        End
37365>>>>>>
37365>>>>>        Send Request_Save of hoSessionDD
37366>>>>>        If (Err) Begin
37368>>>>>            // this shouldn't happen, if it does likely a duplicate session key issue, even through request_save already gave an error we give another one to make tracking down easier
37368>>>>>            Error DFERR_PROGRAM C_$WebAppSessionSaveFailed
37369>>>>>>
37369>>>>>            Function_Return ""
37370>>>>>        End
37370>>>>>>
37370>>>>>       
37370>>>>>        Function_Return sSessionKey        
37371>>>>>    End_Function
37372>>>>>    
37372>>>>>    Function ValidateSession String sSessionKey Boolean bOptLoadWebApp Returns Boolean
37374>>>>>        DateTime dtLastAccess dtCurrent
37374>>>>>        TimeSpan tsDiff
37374>>>>>        Integer iErr iSessionTimeout iSpanMinutes
37374>>>>>        Boolean bResult bCreatingNewSession
37374>>>>>        Boolean bLogWebSession bLoadWebApp
37374>>>>>        Integer eLoginMode
37374>>>>>        String sTime
37374>>>>>        Handle hoSessionDD hoUserDD       
37374>>>>>        
37374>>>>>        Move False to bLoadWebApp
37375>>>>>        If (num_arguments >= 2) Begin
37377>>>>>            Move bOptLoadWebApp to bLoadWebApp
37378>>>>>        End
37378>>>>>>
37378>>>>>        
37378>>>>>        Get phoSessionDD to hoSessionDD
37379>>>>>        Get phoUserDD to hoUserDD
37380>>>>>        
37380>>>>>        Get pbLogWebSession to bLogWebSession
37381>>>>>        Get peLoginMode to eLoginMode
37382>>>>>        
37382>>>>>        // for this object, you can only disable logging if login completely is disabled
37382>>>>>        If (not(bLogWebSession) and (eLoginMode<>lmLoginNone)) Begin
37384>>>>>            Error DFERR_PROGRAM C_$WebSessionLoggingMustBeEnabled
37385>>>>>>
37385>>>>>            Function_Return False
37386>>>>>        End
37386>>>>>>
37386>>>>>
37386>>>>>        //  Clear session properties
37386>>>>>        Set psSessionKey to ""
37387>>>>>        Send UpdateSessionProperties True
37388>>>>>        
37388>>>>>        If not bLogWebSession Begin
37390>>>>>            Forward Get ValidateSession sSessionKey to bResult
37392>>>>>            Function_Return bResult
37393>>>>>        End        
37393>>>>>>
37393>>>>>        
37393>>>>>        Move False to bResult
37394>>>>>        Get piSessionTimeout to iSessionTimeout 
37395>>>>>        
37395>>>>>        //  Check if session exists
37395>>>>>        Send Clear of hoSessionDD
37396>>>>>        Move sSessionKey to WebAppSession.SessionKey
37397>>>>>        Send Find of hoSessionDD EQ Index.1
37398>>>>>            
37398>>>>>        If (Found) Begin
37400>>>>>            //  Calculate timespan between now and last access time
37400>>>>>            Move (CurrentDateTime()) to dtCurrent
37401>>>>>            Move WebAppSession.LastAccessDate to dtLastAccess
37402>>>>>            Get StringToTime of hoSessionDD dtLastAccess WebAppSession.LastAccessTime to dtLastAccess
37403>>>>>            Move (dtCurrent - dtLastAccess) to tsDiff
37404>>>>>            Move (SpanTotalMinutes(tsDiff)) to iSpanMinutes
37405>>>>>            
37405>>>>>            //  Check if session didn't time out
37405>>>>>            If (IsDateValid(dtLastAccess) and (iSessionTimeout <= 0 or (iSpanMinutes < iSessionTimeout)) and WebAppSession.Active = "Y") Begin
37407>>>>>                Forward Get ValidateSession sSessionKey to bResult
37409>>>>>                   
37409>>>>>                If (bResult) Begin
37411>>>>>                    //  Update session record
37411>>>>>                    Get TimeToString of hoSessionDD dtCurrent to sTime 
37412>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessDate to dtCurrent
37413>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessTime to sTime
37414>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.UseCount to (WebAppSession.UseCount + 1)
37415>>>>>                    Get Request_Validate of hoSessionDD to iErr
37416>>>>>                    If (iErr) Begin
37418>>>>>                        // this should not happen. If it does its a programming error
37418>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37419>>>>>>
37419>>>>>                        Function_Return False
37420>>>>>                    End
37420>>>>>>
37420>>>>>                    Send Request_Save of hoSessionDD
37421>>>>>                    
37421>>>>>                    //  Update user properties
37421>>>>>                    Send UpdateSessionProperties False
37422>>>>>                End
37422>>>>>>
37422>>>>>            End
37422>>>>>>
37422>>>>>            Else Begin
37423>>>>>                // Test the Creating New Session Flag to protect against infinite recursion....
37423>>>>>                Get pbCreatingNewSession to bCreatingNewSession
37424>>>>>                
37424>>>>>                If (not(bCreatingNewSession)) Begin
37426>>>>>                    If (not(bLoadWebApp)) Begin
37428>>>>>                        Move False to bResult   //  We can only continue immediately if we were loading the webapp, other operations are not allowed!
37429>>>>>                        Error DFERR_WEBAPP_SESSION_TIMEOUT "Your application session has timed out or is inactive, please login again."
37430>>>>>>
37430>>>>>                        Send NavigateRefresh of ghoWebApp          // refresh the WebApp at the client (triggers a login)
37431>>>>>                    End
37431>>>>>>
37431>>>>>                    Else Begin
37432>>>>>                        Set pbCreatingNewSession to True                    
37433>>>>>                        Get RecreateSession of ghoWebApp to bResult 
37434>>>>>                        Set pbCreatingNewSession to False                        
37435>>>>>                    End
37435>>>>>>
37435>>>>>                End
37435>>>>>>
37435>>>>>            End
37435>>>>>>
37435>>>>>        End
37435>>>>>>
37435>>>>>        Else Begin
37436>>>>>            Error DFERR_WEBAPP_BAD_SESSION_KEY "Session key not known (reload page to recreate session)"
37437>>>>>>
37437>>>>>        End
37437>>>>>>
37437>>>>>        
37437>>>>>        Function_Return bResult
37438>>>>>    End_Function
37439>>>>>    
37439>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
37441>>>>>        If (not(pbPasswordHashing(Self))) Begin
37443>>>>>            Move sPassword to sHash
37444>>>>>            Function_Return True
37445>>>>>        End
37445>>>>>>
37445>>>>>        
37445>>>>>        If (not(CreatePasswordHash(phoCrypto(Self), sPassword, &sHash))) Begin
37447>>>>>            Function_Return False
37448>>>>>        End
37448>>>>>>
37448>>>>>        Move ("V1$" + sHash) to sHash
37449>>>>>        Function_Return True
37450>>>>>    End_Function
37451>>>>>    
37451>>>>>    Function VerifyPasswordHash String sUserPassword String sEnteredPassword Boolean ByRef bShouldUpgrade Returns Boolean
37453>>>>>        If (not(pbPasswordHashing(Self))) Begin
37455>>>>>            Move False to bShouldUpgrade
37456>>>>>            Function_Return (sUserPassword = sEnteredPassword)
37457>>>>>        End
37457>>>>>>
37457>>>>>        
37457>>>>>        String sVersion
37457>>>>>        Move (Left(sUserPassword, 3)) to sVersion
37458>>>>>        If (sVersion = "V1$") Begin
37460>>>>>            If (num_arguments > 2) Move False to bShouldUpgrade
37463>>>>>            Function_Return (VerifyPasswordHash(phoCrypto(Self), sEnteredPassword, Right(sUserPassword, Length(sUserPassword) - 3)))
37464>>>>>        End
37464>>>>>>
37464>>>>>        Else Begin
37465>>>>>            If (num_arguments > 2) Move True to bShouldUpgrade
37468>>>>>            Function_Return False
37469>>>>>        End
37469>>>>>>
37469>>>>>    End_Function
37470>>>>>    
37470>>>>>    Function UserRegister String sLoginName String sPassword Returns Boolean
37472>>>>>        Handle hoUserDD
37472>>>>>        Integer iErr
37472>>>>>        Get phoUserDD to hoUserDD
37473>>>>>        
37473>>>>>        //  Find the user
37473>>>>>        Send Clear of hoUserDD
37474>>>>>        Move sLoginName to WebAppUser.LoginName
37475>>>>>        Send Find of hoUserDD EQ Index.1
37476>>>>>        If (Found) Begin
37478>>>>>            Send Clear of hoUserDD
37479>>>>>            Function_Return False
37480>>>>>        End
37480>>>>>>
37480>>>>>        
37480>>>>>        Send Clear of hoUserDD
37481>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.FullName to sLoginName
37482>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.LoginName to sLoginName
37483>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37485>>>>>            Send Clear of hoUserDD
37486>>>>>            Function_Return False
37487>>>>>        End
37487>>>>>>
37487>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37488>>>>>        Get Request_Validate of hoUserDD to iErr
37489>>>>>        If (iErr) Begin
37491>>>>>            Send Clear of hoUserDD
37492>>>>>            Function_Return False
37493>>>>>        End
37493>>>>>>
37493>>>>>        
37493>>>>>        Send Request_Save of hoUserDD
37494>>>>>        Function_Return (not(Err))
37495>>>>>    End_Function
37496>>>>>    
37496>>>>>    Function UserLogin String sLoginName String sPassword Returns Boolean
37498>>>>>        String sSessionKey sUserPassword
37498>>>>>        Handle hoSessionDD hoUserDD
37498>>>>>        Boolean bMatch bUpgrade
37498>>>>>        
37498>>>>>        Get phoSessionDD to hoSessionDD
37499>>>>>        Get phoUserDD to hoUserDD
37500>>>>>        Integer iErr eLoginMode
37500>>>>>        
37500>>>>>        // Refind session record
37500>>>>>        Get psSessionKey to sSessionKey
37501>>>>>        Send Clear of hoSessionDD
37502>>>>>        Move sSessionKey to WebAppSession.SessionKey
37503>>>>>        Send Find of hoSessionDD EQ Index.1
37504>>>>>        
37504>>>>>        If (Found and WebAppSession.SessionKey = sSessionKey) Begin
37506>>>>>            Get peLoginMode to eLoginMode
37507>>>>>            
37507>>>>>            //  Find the user
37507>>>>>            Move sLoginName to WebAppUser.LoginName
37508>>>>>            Send Find of hoUserDD EQ Index.1
37509>>>>>            
37509>>>>>            // Check username and password
37509>>>>>            If (Found and (Lowercase(sLoginName) = Lowercase(Trim(WebAppUser.LoginName)))) Begin
37511>>>>>                Get Field_Current_Value of hoUserDD Field WebAppUser.Password to sUserPassword
37512>>>>>                Get VerifyPasswordHash (Trim(sUserPassword)) (Trim(sPassword)) (&bUpgrade) to bMatch
37513>>>>>                
37513>>>>>                If (bMatch) Begin
37515>>>>>                    // Store the login
37515>>>>>                    If (bUpgrade) Begin
37517>>>>>                        Get CreatePasswordHash (Trim(sPassword)) (&sPassword) to bUpgrade
37518>>>>>                        If (bUpgrade) Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37521>>>>>                    End
37521>>>>>>
37521>>>>>                    Set Field_Changed_Value of hoUserDD Field WebAppUser.LastLogin to (CurrentDateTime())
37522>>>>>                    Get Request_Validate of hoSessionDD to iErr
37523>>>>>                    If (iErr) Begin
37525>>>>>                        // this should not happen. If it does its a programming error
37525>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37526>>>>>>
37526>>>>>                        Function_Return False
37527>>>>>                    End
37527>>>>>>
37527>>>>>                    
37527>>>>>                    Send Request_Save of hoSessionDD
37528>>>>>                    
37528>>>>>                    // Update session properties
37528>>>>>                    Send UpdateSessionProperties False
37529>>>>>                    Send NotifyChangeRights
37530>>>>>                    Function_Return True
37531>>>>>                End
37531>>>>>>
37531>>>>>                Else Begin
37532>>>>>                    //  We should rely directly on this buffer elsewhere but just be sure
37532>>>>>                    Send Clear of hoUserDD
37533>>>>>                End
37533>>>>>>
37533>>>>>            End
37533>>>>>>
37533>>>>>            Else Begin
37534>>>>>                // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37534>>>>>                Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37535>>>>>            End
37535>>>>>>
37535>>>>>        End
37535>>>>>>
37535>>>>>        Else Begin
37536>>>>>            // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37536>>>>>            Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37537>>>>>        End
37537>>>>>>
37537>>>>>          
37537>>>>>        Function_Return False
37538>>>>>    End_Function
37539>>>>>    
37539>>>>>    Function SetUserPassword String sLoginName String sPassword Returns Boolean
37541>>>>>        Handle hoUserDD
37541>>>>>        Integer iErr
37541>>>>>        Get phoUserDD to hoUserDD
37542>>>>>        
37542>>>>>        //  Find the user
37542>>>>>        Send Clear of hoUserDD
37543>>>>>        Move sLoginName to WebAppUser.LoginName
37544>>>>>        Send Find of hoUserDD EQ Index.1
37545>>>>>        If (not(Found)) Begin
37547>>>>>            Send Clear of hoUserDD
37548>>>>>            Function_Return False
37549>>>>>        End
37549>>>>>>
37549>>>>>        
37549>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37551>>>>>            Send Clear of hoUserDD
37552>>>>>            Function_Return False
37553>>>>>        End
37553>>>>>>
37553>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37554>>>>>        Get Request_Validate of hoUserDD to iErr
37555>>>>>        If (iErr) Begin
37557>>>>>            Send Clear of hoUserDD
37558>>>>>            Function_Return False
37559>>>>>        End
37559>>>>>>
37559>>>>>        
37559>>>>>        Send Request_Save of hoUserDD
37560>>>>>        Function_Return (not(Err))
