40500>>>                Case Break
40501>>>                
40501>>>            Case (NavigateData.eNavigateType=nfFromMain)
40504>>>                // If from main, this is a propbably a main file lookup from a Zoom.
40504>>>                // This is not used often with the drilldown style
40504>>>                Move "Hermano" to sDesdeDondeVengo
40505>>>                Case Break
40506>>>                
40506>>>            Case Else // must be nfUndefined
40506>>>                // This may be the start of a drilldown query or some kind ofcustom query.
40506>>>                // You may want to check NavigateData.NamedValues.
40506>>>                  
40506>>>        Case End
