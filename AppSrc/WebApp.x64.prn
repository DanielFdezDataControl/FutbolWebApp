38889>>>    // This can be used to show and hide buttons based on context.
38889>>>    // This can be called any time the view is active.
38889>>>    Procedure SetActionButtons
38892>>>        tWebNavigateData NavigateData
38892>>>        tWebNavigateData NavigateData
38892>>>        Boolean bHasRecord
38892>>>        Handle hoDD
38892>>>
38892>>>        Get Server to hoDD
38893>>>        Get GetNavigateData to NavigateData
38894>>>        
38894>>>        If (hoDD) Begin
38896>>>            Get HasRecord of hoDD to bHasRecord
38897>>>        End
38897>>>>
38897>>>        Else Begin
38898>>>            Move False to bHasRecord
38899>>>        End
38899>>>>
38899>>>
38899>>>        // let's hide all buttons and then show the ones we want
38899>>>        WebSet pbRender of oEditBtn to False 
38900>>>        WebSet pbRender of oSaveBtn to False
38901>>>        WebSet pbRender of oCancelChangesBtn to False
38902>>>        WebSet pbRender of oDeleteBtn to False
38903>>>
38903>>>        If (NavigateData.bReadOnly) Begin 
38905>>>            WebSet pbRender of oEditBtn to True 
38906>>>        End
38906>>>>
38906>>>        Else Begin
38907>>>            WebSet pbRender of oSaveBtn to True
38908>>>            WebSet pbRender of oCancelChangesBtn to True
38909>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38910>>>        End
38910>>>>
38910>>>    End_Procedure
