38780>>>    // Add code to customize your Zoom View based on how it was invoked.
38780>>>    // Use NavigateData to determine the context this view will be used in.
38780>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
38783>>>
38783>>>        // if this view is being used in multiple contexts, you may need a block of code
38783>>>        // like this to handle customizations. This would include hiding rows and buttons
38783>>>        // (WebSet pbRender) and changing the values of various captions.
38783>>>        Case Begin
38783>>>            Case (NavigateData.eNavigateType = nfFromMain)
38785>>>                // If from main, this is a probably a main file Select to Zoom.
38785>>>                // This is the most typical way to navigate to a zoom.
38785>>>                Case Break
38786>>>                
38786>>>            Case (NavigateData.eNavigateType = nfFromParent)
38789>>>                // If from parent, this is a constrained drill down.
38789>>>                // If needed, you could check NavigateData.iTable to determine the constraining parent.
38789>>>                // This would be unusual - normally you drill down from a parent to a list (Select view).
38789>>>                Case Break
38790>>>                
38790>>>            Case (NavigateData.eNavigateType = nfFromChild)
38793>>>                // If from child, this is a probably a parent Zoom from a Zoom. 
38793>>>                // This is unusual, but it might be used for adding a new child record.
38793>>>                Case Break
38794>>>                
38794>>>            Case Else // must be nfUndefined
38794>>>                // This may be the start of a query or this may be used for some kind of custom operation.
38794>>>                // You may want to check NavigateData.NamedValues.
38794>>>                  
38794>>>        Case End
38794>>>
38794>>>        // Action buttons can be changed dynamically during a Zoom's display lifetime.
38794>>>        // It's best to set these buttons in their own procedure so you can change later.
38794>>>        Send SetActionButtons
38795>>>        
38795>>>        Integer iUserRights
38795>>>        String sLoginName
38795>>>        Get piUserRights of ghoWebSessionManager to iUserRights
38796>>>        Get psLoginName of ghoWebSessionManager to sLoginName
38797>>>        
38797>>>        If (HasRecord(Server(Self))) Begin 
38799>>>            Send SetHeaderCaption    ("Liga:"*liga.Nombre)
38800>>>            Send SetBreadcrumbCaption liga.Nombre
38801>>>            
38801>>>            Send Rebuild_Constraints of oJugadorDD
38802>>>            Send RefreshListFromDD of oJugadoresEquipo_List
38803>>>            
38803>>>            Send Rebuild_Constraints of oEntrenadorDD
38804>>>            Send RefreshListFromDD of oEntrenadorEquipo_List
38805>>>        End
38805>>>>
38805>>>        Else Begin 
38806>>>            If (iUserRights = 7) Begin
38808>>>                Send SetBreadcrumbCaption "Nueva"
38809>>>                Send SetHeaderCaption     "Nueva Liga"                
38810>>>            End
38810>>>>
38810>>>            Else Begin
38811>>>                Send ShowInfoBox "no tiene permiso para crear liga" ("Usuario: "+ sLoginName)
38812>>>                Send NavigateClose Self
38813>>>            End
38813>>>>
38813>>>        End
38813>>>>
38813>>>
38813>>>    End_Procedure   
