36989>>>>>>>    //
36989>>>>>>>    //  Converts the given time to an string that can be saved in the database.
36989>>>>>>>    //
36989>>>>>>>    //  Params:
36989>>>>>>>    //      dtTime  Time to convert
36989>>>>>>>    //  Returns:
36989>>>>>>>    //      String with "HH:MM:SS" format
36989>>>>>>>    //
36989>>>>>>>    Function TimeToString DateTime dtTime Returns String
36991>>>>>>>        String sHours sMinutes sSeconds
36991>>>>>>>        
36991>>>>>>>        //  Extract parts
36991>>>>>>>        Move (String(DateGetHour(dtTime))) to sHours
36992>>>>>>>        Move (String(DateGetMinute(dtTime))) to sMinutes
36993>>>>>>>        Move (String(DateGetSecond(dtTime))) to sSeconds
36994>>>>>>>        
36994>>>>>>>        //  Fill out with 0
36994>>>>>>>        If (Length(sHours) = 1) ;            Move ("0" + sHours) to sHours
36997>>>>>>>        If (Length(sMinutes) = 1) ;            Move ("0" + sMinutes) to sMinutes
37000>>>>>>>        If (Length(sSeconds) = 1) ;            Move ("0" + sSeconds) to sSeconds
37003>>>>>>>        
37003>>>>>>>        Function_Return (sHours + ":" + sMinutes + ":" + sSeconds)
37004>>>>>>>    End_Function
37005>>>>>>>    
37005>>>>>>>    //
37005>>>>>>>    //  Sets the time of the datetime variable to the time in the string.
37005>>>>>>>    //
37005>>>>>>>    //  Params:
37005>>>>>>>    //      dtTime  Datetime variable to add time to
37005>>>>>>>    //      sTimeString String with time in the format "HH:MM:SS"
37005>>>>>>>    //  Returns:
37005>>>>>>>    //      dtDateTime with the loaded time
37005>>>>>>>    //
37005>>>>>>>    Function StringToTime DateTime dtTime String sTimeString Returns DateTime
37007>>>>>>>        String sHours sMinutes sSeconds
37007>>>>>>>        
37007>>>>>>>        //  Extract parts
37007>>>>>>>        Move (Mid(sTimeString, 2, 1)) to sHours
37008>>>>>>>        Move (Mid(sTimeString, 2, 4)) to sMinutes
37009>>>>>>>        Move (Mid(sTimeString, 2, 7)) to sSeconds
37010>>>>>>>        
37010>>>>>>>        //  Set to DateTime
37010>>>>>>>        Move (DateSetHour(dtTime, (Integer(sHours)))) to dtTime
37011>>>>>>>        Move (DateSetMinute(dtTime, (Integer(sMinutes)))) to dtTime
37012>>>>>>>        Move (DateSetSecond(dtTime, (Integer(sSeconds)))) to dtTime
37013>>>>>>>        
37013>>>>>>>        Function_Return dtTime
37014>>>>>>>    End_Function
37015>>>>>>>End_Class
