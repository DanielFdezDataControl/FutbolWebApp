37269>>>>>Class cWebSessionManagerStandard is a cWebSessionManager
37270>>>>>    
37270>>>>>    Procedure Construct_Object
37272>>>>>        Handle hoObj
37272>>>>>        
37272>>>>>        Forward Send Construct_Object
37274>>>>>        
37274>>>>>        Set pbSessionCookieHttpOnly to True
37275>>>>>        
37275>>>>>        Property Handle phoUserDD 0      // Handle to the WebAppUser DDO
37276>>>>>        Property Handle phoSessionDD 0   // Handle to the WebAppSession DDO  
37277>>>>>        Property Handle phoCrypto 0      // Handle to the PasswordHasher
37278>>>>>        
37278>>>>>        Get CreateNamed (RefClass(cWebAppUserDataDictionary)) 'oUserDD' to hoObj
37279>>>>>        Set phoUserDD to hoObj
37280>>>>>        
37280>>>>>        Get CreateNamed (RefClass(cWebAppSessionDataDictionary)) 'oSessionDD' to hoObj
37281>>>>>        Set DDO_Server of hoObj to (phoUserDD(Self))
37282>>>>>        Set phoSessionDD to hoObj
37283>>>>>        
37283>>>>>        Property Handle phoCrypto 0   // Handle to the Cryptographer
37284>>>>>        Get CreateNamed (RefClass(cPasswordHasher)) 'oCrypto' to hoObj
37285>>>>>        Set phoCrypto to hoObj
37286>>>>>        
37286>>>>>        Property Boolean pbPasswordHashing True
37287>>>>>        
37287>>>>>        Property Boolean pbCreatingNewSession False
37288>>>>>        Property String psLoginName
37289>>>>>        Property String psUserName ""
37290>>>>>        Property Integer piUserRights 0
37291>>>>>    End_Procedure
37292>>>>>    
37292>>>>>    Procedure End_Construct_Object
37294>>>>>        Forward Send End_Construct_Object
37296>>>>>        
37296>>>>>        Handle hoCrypto
37296>>>>>        Integer iFieldLen
37296>>>>>        If (pbPasswordHashing(Self)) Begin
37298>>>>>            Get phoCrypto to hoCrypto
37299>>>>>            Get_Attribute DF_FIELD_LENGTH of (RefTable(WebAppUser)) (RefTable(WebAppUser.Password)) to iFieldLen
37302>>>>>            If (iFieldLen < (RequiredBufferSize(hoCrypto) + 3)) Begin
37304>>>>>                Error DFERR_PROGRAM "The password field of WebAppUser is not large enough (128)"
37305>>>>>>
37305>>>>>            End
37305>>>>>>
37305>>>>>        End
37305>>>>>>
37305>>>>>    End_Procedure
37306>>>>>    
37306>>>>>    Function CreateSession String sRemoteAddress Returns String
37308>>>>>        String sSessionKey
37308>>>>>        Integer iErr
37308>>>>>        Boolean bLogWebSession
37308>>>>>        Handle hoSessionDD       
37308>>>>>        Get phoSessionDD to hoSessionDD
37309>>>>>        
37309>>>>>        //  Get session key
37309>>>>>        Forward Get CreateSession sRemoteAddress to sSessionKey
37311>>>>>        
37311>>>>>        Get pbLogWebSession to bLogWebSession
37312>>>>>        If not bLogWebSession Begin
37314>>>>>            Function_Return sSessionKey        
37315>>>>>        End
37315>>>>>>
37315>>>>>
37315>>>>>        //  Store session
37315>>>>>        Send Clear of hoSessionDD
37316>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.SessionKey to sSessionKey
37317>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.RemoteAddress to sRemoteAddress
37318>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.Active to "Y"
37319>>>>>        Get Request_Validate of hoSessionDD to iErr
37320>>>>>        If (iErr) Begin
37322>>>>>            // this should not happen. If it does its a programming error
37322>>>>>            Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37323>>>>>>
37323>>>>>            Function_Return ""
37324>>>>>        End
37324>>>>>>
37324>>>>>        Send Request_Save of hoSessionDD
37325>>>>>        If (Err) Begin
37327>>>>>            // this shouldn't happen, if it does likely a duplicate session key issue, even through request_save already gave an error we give another one to make tracking down easier
37327>>>>>            Error DFERR_PROGRAM C_$WebAppSessionSaveFailed
37328>>>>>>
37328>>>>>            Function_Return ""
37329>>>>>        End
37329>>>>>>
37329>>>>>       
37329>>>>>        Function_Return sSessionKey        
37330>>>>>    End_Function
37331>>>>>    
37331>>>>>    Function ValidateSession String sSessionKey Boolean bOptLoadWebApp Returns Boolean
37333>>>>>        DateTime dtLastAccess dtCurrent
37333>>>>>        TimeSpan tsDiff
37333>>>>>        Integer iErr iSessionTimeout iSpanMinutes
37333>>>>>        Boolean bResult bCreatingNewSession
37333>>>>>        Boolean bLogWebSession bLoadWebApp
37333>>>>>        Integer eLoginMode
37333>>>>>        String sTime
37333>>>>>        Handle hoSessionDD hoUserDD       
37333>>>>>        
37333>>>>>        Move False to bLoadWebApp
37334>>>>>        If (num_arguments >= 2) Begin
37336>>>>>            Move bOptLoadWebApp to bLoadWebApp
37337>>>>>        End
37337>>>>>>
37337>>>>>        
37337>>>>>        Get phoSessionDD to hoSessionDD
37338>>>>>        Get phoUserDD to hoUserDD
37339>>>>>        
37339>>>>>        Get pbLogWebSession to bLogWebSession
37340>>>>>        Get peLoginMode to eLoginMode
37341>>>>>        
37341>>>>>        // for this object, you can only disable logging if login completely is disabled
37341>>>>>        If (not(bLogWebSession) and (eLoginMode<>lmLoginNone)) Begin
37343>>>>>            Error DFERR_PROGRAM C_$WebSessionLoggingMustBeEnabled
37344>>>>>>
37344>>>>>            Function_Return False
37345>>>>>        End
37345>>>>>>
37345>>>>>
37345>>>>>        //  Clear session properties
37345>>>>>        Set psSessionKey to ""
37346>>>>>        Send UpdateSessionProperties True
37347>>>>>        
37347>>>>>        If not bLogWebSession Begin
37349>>>>>            Forward Get ValidateSession sSessionKey to bResult
37351>>>>>            Function_Return bResult
37352>>>>>        End        
37352>>>>>>
37352>>>>>        
37352>>>>>        Move False to bResult
37353>>>>>        Get piSessionTimeout to iSessionTimeout 
37354>>>>>        
37354>>>>>        //  Check if session exists
37354>>>>>        Send Clear of hoSessionDD
37355>>>>>        Move sSessionKey to WebAppSession.SessionKey
37356>>>>>        Send Find of hoSessionDD EQ Index.1
37357>>>>>            
37357>>>>>        If (Found) Begin
37359>>>>>            //  Calculate timespan between now and last access time
37359>>>>>            Move (CurrentDateTime()) to dtCurrent
37360>>>>>            Move WebAppSession.LastAccessDate to dtLastAccess
37361>>>>>            Get StringToTime of hoSessionDD dtLastAccess WebAppSession.LastAccessTime to dtLastAccess
37362>>>>>            Move (dtCurrent - dtLastAccess) to tsDiff
37363>>>>>            Move (SpanTotalMinutes(tsDiff)) to iSpanMinutes
37364>>>>>            
37364>>>>>            //  Check if session didn't time out
37364>>>>>            If (IsDateValid(dtLastAccess) and (iSessionTimeout <= 0 or (iSpanMinutes < iSessionTimeout)) and WebAppSession.Active = "Y") Begin
37366>>>>>                Forward Get ValidateSession sSessionKey to bResult
37368>>>>>                   
37368>>>>>                If (bResult) Begin
37370>>>>>                    //  Update session record
37370>>>>>                    Get TimeToString of hoSessionDD dtCurrent to sTime 
37371>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessDate to dtCurrent
37372>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessTime to sTime
37373>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.UseCount to (WebAppSession.UseCount + 1)
37374>>>>>                    Get Request_Validate of hoSessionDD to iErr
37375>>>>>                    If (iErr) Begin
37377>>>>>                        // this should not happen. If it does its a programming error
37377>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37378>>>>>>
37378>>>>>                        Function_Return False
37379>>>>>                    End
37379>>>>>>
37379>>>>>                    Send Request_Save of hoSessionDD
37380>>>>>                    
37380>>>>>                    //  Update user properties
37380>>>>>                    Send UpdateSessionProperties False
37381>>>>>                End
37381>>>>>>
37381>>>>>            End
37381>>>>>>
37381>>>>>            Else Begin
37382>>>>>                // Test the Creating New Session Flag to protect against infinite recursion....
37382>>>>>                Get pbCreatingNewSession to bCreatingNewSession
37383>>>>>                
37383>>>>>                If (not(bCreatingNewSession)) Begin
37385>>>>>                    If (not(bLoadWebApp)) Begin
37387>>>>>                        Move False to bResult   //  We can only continue immediately if we were loading the webapp, other operations are not allowed!
37388>>>>>                        Error DFERR_WEBAPP_SESSION_TIMEOUT "Your application session has timed out or is inactive, please login again."
37389>>>>>>
37389>>>>>                        Send NavigateRefresh of ghoWebApp          // refresh the WebApp at the client (triggers a login)
37390>>>>>                    End
37390>>>>>>
37390>>>>>                    Else Begin
37391>>>>>                        Set pbCreatingNewSession to True                    
37392>>>>>                        Get RecreateSession of ghoWebApp to bResult 
37393>>>>>                        Set pbCreatingNewSession to False                        
37394>>>>>                    End
37394>>>>>>
37394>>>>>                End
37394>>>>>>
37394>>>>>            End
37394>>>>>>
37394>>>>>        End
37394>>>>>>
37394>>>>>        Else Begin
37395>>>>>            Error DFERR_WEBAPP_BAD_SESSION_KEY "Session key not known (reload page to recreate session)"
37396>>>>>>
37396>>>>>        End
37396>>>>>>
37396>>>>>        
37396>>>>>        Function_Return bResult
37397>>>>>    End_Function
37398>>>>>    
37398>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
37400>>>>>        If (not(pbPasswordHashing(Self))) Begin
37402>>>>>            Move sPassword to sHash
37403>>>>>            Function_Return True
37404>>>>>        End
37404>>>>>>
37404>>>>>        
37404>>>>>        If (not(CreatePasswordHash(phoCrypto(Self), sPassword, &sHash))) Begin
37406>>>>>            Function_Return False
37407>>>>>        End
37407>>>>>>
37407>>>>>        Move ("V1$" + sHash) to sHash
37408>>>>>        Function_Return True
37409>>>>>    End_Function
37410>>>>>    
37410>>>>>    Function VerifyPasswordHash String sUserPassword String sEnteredPassword Boolean ByRef bShouldUpgrade Returns Boolean
37412>>>>>        If (not(pbPasswordHashing(Self))) Begin
37414>>>>>            Move False to bShouldUpgrade
37415>>>>>            Function_Return (sUserPassword = sEnteredPassword)
37416>>>>>        End
37416>>>>>>
37416>>>>>        
37416>>>>>        String sVersion
37416>>>>>        Move (Left(sUserPassword, 3)) to sVersion
37417>>>>>        If (sVersion = "V1$") Begin
37419>>>>>            If (num_arguments > 2) Move False to bShouldUpgrade
37422>>>>>            Function_Return (VerifyPasswordHash(phoCrypto(Self), sEnteredPassword, Right(sUserPassword, Length(sUserPassword) - 3)))
37423>>>>>        End
37423>>>>>>
37423>>>>>        Else Begin
37424>>>>>            If (num_arguments > 2) Move True to bShouldUpgrade
37427>>>>>            Function_Return False
37428>>>>>        End
37428>>>>>>
37428>>>>>    End_Function
37429>>>>>    
37429>>>>>    Function UserRegister String sLoginName String sPassword Returns Boolean
37431>>>>>        Handle hoUserDD
37431>>>>>        Integer iErr
37431>>>>>        Get phoUserDD to hoUserDD
37432>>>>>        
37432>>>>>        //  Find the user
37432>>>>>        Send Clear of hoUserDD
37433>>>>>        Move sLoginName to WebAppUser.LoginName
37434>>>>>        Send Find of hoUserDD EQ Index.1
37435>>>>>        If (Found) Begin
37437>>>>>            Send Clear of hoUserDD
37438>>>>>            Function_Return False
37439>>>>>        End
37439>>>>>>
37439>>>>>        
37439>>>>>        Send Clear of hoUserDD
37440>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.FullName to sLoginName
37441>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.LoginName to sLoginName
37442>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37444>>>>>            Send Clear of hoUserDD
37445>>>>>            Function_Return False
37446>>>>>        End
37446>>>>>>
37446>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37447>>>>>        Get Request_Validate of hoUserDD to iErr
37448>>>>>        If (iErr) Begin
37450>>>>>            Send Clear of hoUserDD
37451>>>>>            Function_Return False
37452>>>>>        End
37452>>>>>>
37452>>>>>        
37452>>>>>        Send Request_Save of hoUserDD
37453>>>>>        Function_Return (not(Err))
37454>>>>>    End_Function
37455>>>>>    
37455>>>>>    Function UserLogin String sLoginName String sPassword Returns Boolean
37457>>>>>        String sSessionKey sUserPassword
37457>>>>>        Handle hoSessionDD hoUserDD
37457>>>>>        Boolean bMatch bUpgrade
37457>>>>>        
37457>>>>>        Get phoSessionDD to hoSessionDD
37458>>>>>        Get phoUserDD to hoUserDD
37459>>>>>        Integer iErr eLoginMode
37459>>>>>        
37459>>>>>        // Refind session record
37459>>>>>        Get psSessionKey to sSessionKey
37460>>>>>        Send Clear of hoSessionDD
37461>>>>>        Move sSessionKey to WebAppSession.SessionKey
37462>>>>>        Send Find of hoSessionDD EQ Index.1
37463>>>>>        
37463>>>>>        If (Found and WebAppSession.SessionKey = sSessionKey) Begin
37465>>>>>            Get peLoginMode to eLoginMode
37466>>>>>            
37466>>>>>            //  Find the user
37466>>>>>            Move sLoginName to WebAppUser.LoginName
37467>>>>>            Send Find of hoUserDD EQ Index.1
37468>>>>>            
37468>>>>>            // Check username and password
37468>>>>>            If (Found and (Lowercase(sLoginName) = Lowercase(Trim(WebAppUser.LoginName)))) Begin
37470>>>>>                Get Field_Current_Value of hoUserDD Field WebAppUser.Password to sUserPassword
37471>>>>>                Get VerifyPasswordHash (Trim(sUserPassword)) (Trim(sPassword)) (&bUpgrade) to bMatch
37472>>>>>                
37472>>>>>                If (bMatch) Begin
37474>>>>>                    // Store the login
37474>>>>>                    If (bUpgrade) Begin
37476>>>>>                        Get CreatePasswordHash (Trim(sPassword)) (&sPassword) to bUpgrade
37477>>>>>                        If (bUpgrade) Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37480>>>>>                    End
37480>>>>>>
37480>>>>>                    Set Field_Changed_Value of hoUserDD Field WebAppUser.LastLogin to (CurrentDateTime())
37481>>>>>                    Get Request_Validate of hoSessionDD to iErr
37482>>>>>                    If (iErr) Begin
37484>>>>>                        // this should not happen. If it does its a programming error
37484>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37485>>>>>>
37485>>>>>                        Function_Return False
37486>>>>>                    End
37486>>>>>>
37486>>>>>                    
37486>>>>>                    Send Request_Save of hoSessionDD
37487>>>>>                    
37487>>>>>                    // Update session properties
37487>>>>>                    Send UpdateSessionProperties False
37488>>>>>                    Send NotifyChangeRights
37489>>>>>                    Function_Return True
37490>>>>>                End
37490>>>>>>
37490>>>>>                Else Begin
37491>>>>>                    //  We should rely directly on this buffer elsewhere but just be sure
37491>>>>>                    Send Clear of hoUserDD
37492>>>>>                End
37492>>>>>>
37492>>>>>            End
37492>>>>>>
37492>>>>>            Else Begin
37493>>>>>                // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37493>>>>>                Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37494>>>>>            End
37494>>>>>>
37494>>>>>        End
37494>>>>>>
37494>>>>>        Else Begin
37495>>>>>            // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37495>>>>>            Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37496>>>>>        End
37496>>>>>>
37496>>>>>          
37496>>>>>        Function_Return False
37497>>>>>    End_Function
37498>>>>>    
37498>>>>>    Function SetUserPassword String sLoginName String sPassword Returns Boolean
37500>>>>>        Handle hoUserDD
37500>>>>>        Integer iErr
37500>>>>>        Get phoUserDD to hoUserDD
37501>>>>>        
37501>>>>>        //  Find the user
37501>>>>>        Send Clear of hoUserDD
37502>>>>>        Move sLoginName to WebAppUser.LoginName
37503>>>>>        Send Find of hoUserDD EQ Index.1
37504>>>>>        If (not(Found)) Begin
37506>>>>>            Send Clear of hoUserDD
37507>>>>>            Function_Return False
37508>>>>>        End
37508>>>>>>
37508>>>>>        
37508>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37510>>>>>            Send Clear of hoUserDD
37511>>>>>            Function_Return False
37512>>>>>        End
37512>>>>>>
37512>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37513>>>>>        Get Request_Validate of hoUserDD to iErr
37514>>>>>        If (iErr) Begin
37516>>>>>            Send Clear of hoUserDD
37517>>>>>            Function_Return False
37518>>>>>        End
37518>>>>>>
37518>>>>>        
37518>>>>>        Send Request_Save of hoUserDD
37519>>>>>        Function_Return (not(Err))
37520>>>>>    End_Function
37521>>>>>    
37521>>>>>    Function IsLoggedIn Returns Boolean
37523>>>>>        String sLoginName
37523>>>>>        Boolean bLogWebSession bLoggedIn
37523>>>>>        
37523>>>>>        Get pbLogWebSession to bLogWebSession
37524>>>>>        If not bLogWebSession Begin
37526>>>>>            Forward Get IsLoggedIn to bLoggedIn
37528>>>>>            Function_Return bLoggedIn
37529>>>>>        End
37529>>>>>>
37529>>>>>        
37529>>>>>        Get psLoginName to sLoginName
37530>>>>>        
37530>>>>>        Function_Return (sLoginName <> "")
37531>>>>>    End_Function
37532>>>>>    
37532>>>>>    
37532>>>>>    //
37532>>>>>    // This procedure is called when validating a session and after logging in. Its purpose is to 
37532>>>>>    // update properties based on the session and user data. Augment this function to update 
37532>>>>>    // properties based on the session / user table. Note that WebAppUser and WebAppSession contain
37532>>>>>    // the right records when this procedure is called.
37532>>>>>    //
37532>>>>>    // Params:
37532>>>>>    //      bClear   True if the procedure is called before session validation to clear properties.
37532>>>>>    //
37532>>>>>    Procedure UpdateSessionProperties Boolean bClear
37534>>>>>        Handle hoUserDD
37534>>>>>        
37534>>>>>        Get phoUserDD to hoUserDD
37535>>>>>        
37535>>>>>        //  Update user properties
37535>>>>>        If (not(bClear) and HasRecord(hoUserDD)) Begin
37537>>>>>            Set psUsername to (Trim(WebAppUser.FullName))
37538>>>>>            Set psLoginName to (Trim(WebAppUser.LoginName))
37539>>>>>            Set piUserRights to WebAppUser.Rights
37540>>>>>            
37540>>>>>            Send OnSessionPropertiesSet 
37541>>>>>        End
37541>>>>>>
37541>>>>>        Else Begin
37542>>>>>            Set psUsername to ""
37543>>>>>            Set psLoginName to ""
37544>>>>>            Set piUserRights to 0
37545>>>>>            
37545>>>>>            Send OnSessionPropertiesClear
37546>>>>>        End
37546>>>>>>
37546>>>>>    End_Procedure
37547>>>>>    
37547>>>>>    Procedure OnSessionPropertiesSet
37549>>>>>        //  Empty event stub
37549>>>>>    End_Procedure
37550>>>>>    
37550>>>>>    Procedure OnSessionPropertiesClear
37552>>>>>        //  Empty event stub
37552>>>>>    End_Procedure
37553>>>>>    
37553>>>>>    Procedure EndSession
37555>>>>>        Integer iErr
37555>>>>>        Boolean bLogWebSession
37555>>>>>        Handle hoSessionDD       
37555>>>>>        
37555>>>>>        Get phoSessionDD to hoSessionDD
37556>>>>>        Get pbLogWebSession to bLogWebSession
37557>>>>>        If not bLogWebSession Begin
37559>>>>>            Forward Send EndSession
37561>>>>>            Procedure_Return
37562>>>>>        End
37562>>>>>>
37562>>>>>            
37562>>>>>        //  Check if session exists
37562>>>>>        Send Clear of hoSessionDD
37563>>>>>        Get psSessionKey to WebAppSession.SessionKey
37564>>>>>        
37564>>>>>        Send Find of hoSessionDD EQ Index.1
37565>>>>>        If (Found) Begin
37567>>>>>            Set Field_Changed_Value of hoSessionDD Field WebAppSession.Active to "N"
37568>>>>>            Get Request_Validate of hoSessionDD to iErr
37569>>>>>            If (iErr) Begin
37571>>>>>                // this should not happen. If it does its a programming error
37571>>>>>                Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37572>>>>>>
37572>>>>>                Procedure_Return
37573>>>>>            End
37573>>>>>>
37573>>>>>            Send Request_Save of hoSessionDD
37574>>>>>        End
37574>>>>>>
37574>>>>>    End_Procedure
37575>>>>>
37575>>>>>End_Class
