37663>>>    Procedure DoLogin
37666>>>        String sLoginName sPassword sPrevStateHash
37666>>>        Boolean bResult
37666>>>        
37666>>>        WebGet psValue of oLoginName to sLoginName
37667>>>        WebGet psValue of oPassword to sPassword
37668>>>        
37668>>>        Get UserLogin of ghoWebSessionManager sLoginName sPassword to bResult
37669>>>        
37669>>>        If (bResult) Begin
37671>>>            Send Hide of oLogin
37672>>>            Send ShowHeader of ghoWebApp
37673>>>            WebSet psCSSClass of ghoWebApp to ""
37674>>>            
37674>>>            WebGet psPrevStateHash to sPrevStateHash
37675>>>            Send NavigateToStateHash of ghoWebApp sPrevStateHash True
37676>>>            
37676>>>            // clear the login values. we don't want to return the login id & password as synchronized properties....
37676>>>            WebSet psValue of oLoginName to ""
37677>>>            WebSet psValue of oPassword  to ""
37678>>>            WebSet pbVisible of oWarning to False
37679>>>        End
37679>>>>
37679>>>        Else Begin
37680>>>            WebSet pbVisible of oWarning to True
37681>>>        End
37681>>>>
37681>>>    End_Procedure
37682>>>    
37682>>>    Procedure OnSubmit
37685>>>        Send DoLogin
37686>>>    End_Procedure
