37133>>>>>>>    Function CreatePasswordHashEx UInteger uiAlgo UInteger uiSaltSize String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
37135>>>>>>>        UChar[] ucaSalt
37136>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
37137>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
37140>>>>>>>        
37140>>>>>>>        If (num_arguments > 4) Begin
37142>>>>>>>            Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash, uiOptTimeCost))
37143>>>>>>>        End
37143>>>>>>>>
37143>>>>>>>        Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash))
37144>>>>>>>    End_Function
37145>>>>>>>    
37145>>>>>>>    Function VerifyPasswordHash String sPassword String sHash Returns Boolean
37147>>>>>>>        Boolean bRequiresTimeCost
37147>>>>>>>        UInteger uiAlgo uiTimeCost
37147>>>>>>>        Integer iBegin iEnd
37147>>>>>>>        String sSalt
37147>>>>>>>        
37147>>>>>>>        Move 1 to iBegin
37148>>>>>>>        
37148>>>>>>>        // Parse Algo
37148>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
37149>>>>>>>        If (not(iEnd)) Function_Return False
37152>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiAlgo
37153>>>>>>>        
37153>>>>>>>        // Parse Salt
37153>>>>>>>        Move (iEnd + 1) to iBegin
37154>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
37155>>>>>>>        If (not(iEnd)) Function_Return False
37158>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to sSalt
37159>>>>>>>        
37159>>>>>>>        Case Begin
37159>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
37161>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
37164>>>>>>>                Move True to bRequiresTimeCost
37165>>>>>>>                Case Break
37166>>>>>>>            Case Else
37166>>>>>>>                Error 8710 "Invalid algorithm selected."
37167>>>>>>>>
37167>>>>>>>                Function_Return False
37168>>>>>>>        Case End
37168>>>>>>>        
37168>>>>>>>        // Parse optional timecost
37168>>>>>>>        If (bRequiresTimeCost) Begin
37170>>>>>>>            Move (iEnd + 1) to iBegin
37171>>>>>>>            Move (Pos("$", sHash, iBegin)) to iEnd
37172>>>>>>>            If (not(iEnd)) Function_Return False
37175>>>>>>>            Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiTimeCost
37176>>>>>>>        End
37176>>>>>>>>
37176>>>>>>>        
37176>>>>>>>        // Parse rest hash
37176>>>>>>>        Move (iEnd + 1) to iBegin
37177>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
37178>>>>>>>        If (iEnd) Function_Return False // inverse check if there are any other errors.
37181>>>>>>>        
37181>>>>>>>        // Base64Decode
37181>>>>>>>        UChar[] ucaSalt
37182>>>>>>>        Get Base64DecodeArr sSalt to ucaSalt
37183>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
37186>>>>>>>        
37186>>>>>>>        // Create new hash
37186>>>>>>>        String sNewHash
37186>>>>>>>        If (bRequiresTimeCost) Begin
37188>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash, uiTimeCost))) Begin
37190>>>>>>>                Function_Return False 
37191>>>>>>>            End
37191>>>>>>>>
37191>>>>>>>        End
37191>>>>>>>>
37191>>>>>>>        Else Begin
37192>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash))) Begin
37194>>>>>>>                Function_Return False 
37195>>>>>>>            End
37195>>>>>>>>
37195>>>>>>>        End
37195>>>>>>>>
37195>>>>>>>        Function_Return (sNewHash = sHash)
37196>>>>>>>    End_Function
37197>>>>>>>    
37197>>>>>>>    Function RequiredBufferSizeEx UInteger uiAlgo UInteger uiSaltSize UInteger uiOptTimeCost Returns UBigInt
37199>>>>>>>        Boolean bRequireTimeCost
37199>>>>>>>        UBigInt ullSize
37199>>>>>>>        UChar[] ucaSalt
37200>>>>>>>        String sSalt
37200>>>>>>>        
37200>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
37201>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
37202>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return 0
37205>>>>>>>        
37205>>>>>>>        Case Begin
37205>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
37207>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA256" to ullSize
37208>>>>>>>                Move True to bRequireTimeCost
37209>>>>>>>                Case Break
37210>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
37213>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA512" to ullSize
37214>>>>>>>                Move True to bRequireTimeCost
37215>>>>>>>                Case Break
37216>>>>>>>            Case Else
37216>>>>>>>                Error 8710 "Invalid algorithm selected."
37217>>>>>>>>
37217>>>>>>>                Function_Return 0
37218>>>>>>>        Case End
37218>>>>>>>        
37218>>>>>>>        // calculate base64 in a non-floating-manner
37218>>>>>>>        Move (((ullSize + 3 -1) / 3) * 4) to ullSize
37219>>>>>>>        
37219>>>>>>>        Move (ullSize + SizeOfString(String(uiAlgo))) to ullSize
37220>>>>>>>        Move (ullSize + SizeOfString(sSalt)) to ullSize
37221>>>>>>>        If (bRequireTimeCost) Begin
37223>>>>>>>            Move (ullSize + SizeOfString(String(uiOptTimeCost))) to ullSize
37224>>>>>>>            Move (ullSize + 3 /*$*/) to ullSize
37225>>>>>>>        End
37225>>>>>>>>
37225>>>>>>>        Else Begin
37226>>>>>>>            Move (ullSize + 2 /*$*/) to ullSize
37227>>>>>>>        End
37227>>>>>>>>
37227>>>>>>>        
37227>>>>>>>        Function_Return ullSize
37228>>>>>>>    End_Function
37229>>>>>>>End_Class
