39482>>>    // This can be used to show and hide buttons based on context.
39482>>>    // This can be called any time the view is active.
39482>>>    Procedure SetActionButtons
39485>>>        tWebNavigateData NavigateData
39485>>>        tWebNavigateData NavigateData
39485>>>        Boolean bHasRecord
39485>>>        Handle hoDD
39485>>>
39485>>>        Get Server to hoDD
39486>>>        Get GetNavigateData to NavigateData
39487>>>        
39487>>>        If (hoDD) Begin
39489>>>            Get HasRecord of hoDD to bHasRecord
39490>>>        End
39490>>>>
39490>>>        Else Begin
39491>>>            Move False to bHasRecord
39492>>>        End
39492>>>>
39492>>>
39492>>>        // let's hide all buttons and then show the ones we want
39492>>>        WebSet pbRender of oEditBtn to False 
39493>>>        WebSet pbRender of oSaveBtn to False
39494>>>        WebSet pbRender of oCancelChangesBtn to False
39495>>>        WebSet pbRender of oDeleteBtn to False
39496>>>
39496>>>        If (NavigateData.bReadOnly) Begin 
39498>>>            WebSet pbRender of oEditBtn to True 
39499>>>        End
39499>>>>
39499>>>        Else Begin
39500>>>            WebSet pbRender of oSaveBtn to True
39501>>>            WebSet pbRender of oCancelChangesBtn to True
39502>>>            WebSet pbRender of oDeleteBtn to bHasRecord
39503>>>        End
39503>>>>
39503>>>    End_Procedure
39504>>>
39504>>>    // this will close the view after a save
39504>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
39507>>>        Send NavigateClose Self
39508>>>    End_Procedure
39509>>>
39509>>>    // this will close the view after a delete
39509>>>    Procedure OnViewDeleted Handle hoDDO
39512>>>        Send NavigateClose Self
39513>>>    End_Procedure
39514>>>
39514>>>    // Add code to customize your Zoom View based on how it was invoked.
39514>>>    // Use NavigateData to determine the context this view will be used in.
39514>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
39517>>>
39517>>>        // if this view is being used in multiple contexts, you may need a block of code
39517>>>        // like this to handle customizations. This would include hiding rows and buttons
39517>>>        // (WebSet pbRender) and changing the values of various captions.
39517>>>        Case Begin
39517>>>            Case (NavigateData.eNavigateType = nfFromMain)
39519>>>                // If from main, this is a probably a main file Select to Zoom.
39519>>>                // This is the most typical way to navigate to a zoom.
39519>>>                Case Break
39520>>>                
39520>>>            Case (NavigateData.eNavigateType = nfFromParent)
39523>>>                // If from parent, this is a constrained drill down.
39523>>>                // If needed, you could check NavigateData.iTable to determine the constraining parent.
39523>>>                // This would be unusual - normally you drill down from a parent to a list (Select view).
39523>>>                Case Break
39524>>>                
39524>>>            Case (NavigateData.eNavigateType = nfFromChild)
39527>>>                // If from child, this is a probably a parent Zoom from a Zoom. 
39527>>>                // This is unusual, but it might be used for adding a new child record.
39527>>>                Case Break
39528>>>                
39528>>>            Case Else // must be nfUndefined
39528>>>                // This may be the start of a query or this may be used for some kind of custom operation.
39528>>>                // You may want to check NavigateData.NamedValues.
39528>>>                  
39528>>>        Case End
39528>>>
39528>>>        // Action buttons can be changed dynamically during a Zoom's display lifetime.
39528>>>        // It's best to set these buttons in their own procedure so you can change later.
39528>>>        Send SetActionButtons
39529>>>
39529>>>        If (HasRecord(Server(Self))) Begin 
39531>>>            Send SetHeaderCaption    ("Entrenador:"*entrenador.Nombre)
39532>>>            Send SetBreadcrumbCaption entrenador.Nombre
39533>>>        End
39533>>>>
39533>>>        Else Begin 
39534>>>            Send SetHeaderCaption     "Nuevo entrenador"
39535>>>            Send SetBreadcrumbCaption "Nuevo"
39536>>>        End
39536>>>>
39536>>>    End_Procedure
39537>>>
39537>>>End_Object
