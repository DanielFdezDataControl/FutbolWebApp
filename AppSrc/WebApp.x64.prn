39382>>>    // This can be used to show and hide buttons based on context.
39382>>>    // This can be called any time the view is active.
39382>>>    Procedure SetActionButtons
39385>>>        tWebNavigateData NavigateData
39385>>>        tWebNavigateData NavigateData
39385>>>        Boolean bHasRecord
39385>>>        Handle hoDD
39385>>>
39385>>>        Get Server to hoDD
39386>>>        Get GetNavigateData to NavigateData
39387>>>        
39387>>>        If (hoDD) Begin
39389>>>            Get HasRecord of hoDD to bHasRecord
39390>>>        End
39390>>>>
39390>>>        Else Begin
39391>>>            Move False to bHasRecord
39392>>>        End
39392>>>>
39392>>>
39392>>>        // let's hide all buttons and then show the ones we want
39392>>>        WebSet pbRender of oEditBtn to False 
39393>>>        WebSet pbRender of oSaveBtn to False
39394>>>        WebSet pbRender of oCancelChangesBtn to False
39395>>>        WebSet pbRender of oDeleteBtn to False
39396>>>
39396>>>        If (NavigateData.bReadOnly) Begin 
39398>>>            WebSet pbRender of oEditBtn to True 
39399>>>        End
39399>>>>
39399>>>        Else Begin
39400>>>            WebSet pbRender of oSaveBtn to True
39401>>>            WebSet pbRender of oCancelChangesBtn to True
39402>>>            WebSet pbRender of oDeleteBtn to bHasRecord
39403>>>        End
39403>>>>
39403>>>    End_Procedure
39404>>>
