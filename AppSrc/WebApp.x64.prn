40166>>>        // (WebSet pbRender) and changing the values of various captions.
40166>>>        Case Begin
40166>>>            Case (NavigateData.eNavigateType = nfFromMain)
40168>>>                // If from main, this is a probably a main file Select to Zoom.
40168>>>                // This is the most typical way to navigate to a zoom.
40168>>>                Case Break
40169>>>                
40169>>>            Case (NavigateData.eNavigateType = nfFromParent)
40172>>>                // If from parent, this is a constrained drill down.
40172>>>                // If needed, you could check NavigateData.iTable to determine the constraining parent.
40172>>>                // This would be unusual - normally you drill down from a parent to a list (Select view).
40172>>>                Case Break
40173>>>                
40173>>>            Case (NavigateData.eNavigateType = nfFromChild)
40176>>>                // If from child, this is a probably a parent Zoom from a Zoom. 
40176>>>                // This is unusual, but it might be used for adding a new child record.
40176>>>                Case Break
40177>>>                
40177>>>            Case Else // must be nfUndefined
40177>>>                // This may be the start of a query or this may be used for some kind of custom operation.
40177>>>                // You may want to check NavigateData.NamedValues.
40177>>>                  
40177>>>        Case End
40177>>>
40177>>>        // Action buttons can be changed dynamically during a Zoom's display lifetime.
40177>>>        // It's best to set these buttons in their own procedure so you can change later.
40177>>>        Send SetActionButtons
40178>>>        If (HasRecord(Server(Self))) Begin 
40180>>>            Send SetHeaderCaption    ("Posición:"*posicion.Nombre)
40181>>>            Send SetBreadcrumbCaption posicion.Nombre
40182>>>        End
40182>>>>
40182>>>        Else Begin 
40183>>>            Send SetHeaderCaption     "Nueva posición"
40184>>>            Send SetBreadcrumbCaption "Nueva"
40185>>>        End
40185>>>>
40185>>>    End_Procedure
40186>>>
